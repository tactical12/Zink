<Window 
    x:Class="Zink.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Zink"
    Title="Zink">

    <Grid x:Name="RootGrid" Background="Transparent">

        <Grid.Resources>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>

            <SolidColorBrush x:Key="NavigationViewItemBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#20FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#40FFFFFF"/>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <NavigationView
            x:Name="SidebarNav"
            x:FieldModifier="public"
            Grid.Column="0"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="True"
            PaneDisplayMode="Left"
            PaneTitle="Zink"
            IsSettingsVisible="False"
            SelectionChanged="SidebarNav_SelectionChanged">

            <NavigationView.MenuItems>

                <NavigationViewItem Content="Search" Tag="Search">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Find"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Home" Tag="Home">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Music" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE189;"/>
                    </NavigationViewItem.Icon>

                    <NavigationViewItem.MenuItems>

                        <NavigationViewItem Content="Music Player" SelectsOnInvoked="False">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE768;"/>
                            </NavigationViewItem.Icon>

                            <NavigationViewItem.MenuItems>

                                <NavigationViewItem Content="Zink Music" Tag="MusicPlayer">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE189;"/>
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>

                                <NavigationViewItem Content="Music Library" Tag="MusicLibrary">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE8F1;"/>
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>

                                <NavigationViewItemHeader Content="Settings" />

                                <NavigationViewItem Content="Equalizer" Tag="Equalizer">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE993;"/>
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>

                                <NavigationViewItem Content="Visualizer" Tag="Visualizer">
                                    <NavigationViewItem.Icon>
                                        <FontIcon Glyph="&#xE9D9;"/>
                                    </NavigationViewItem.Icon>
                                </NavigationViewItem>

                            </NavigationViewItem.MenuItems>
                        </NavigationViewItem>

                        <NavigationViewItem Content="YouTube Music" Tag="YouTubeMusic">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Play"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Amazon Music" Tag="AmazonMusic">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Play"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Spotify" Tag="Spotify">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#x1F3B5;"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Spotify Widget" Tag="SpotifyWidget">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Radio" Tag="Radio">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Audio"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Liked radio songs" Tag="LikedRadioSongs">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Like"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Radio Widget" Tag="RadioWidget">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <NavigationViewItem Content="Video" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Video"/>
                    </NavigationViewItem.Icon>

                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Video Player" Tag="VideoPlayer">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Play"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Video Library" Tag="VideoLibrary">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Library"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Screen Recorder" Tag="ScreenRecorder">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Camera"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <NavigationViewItem Content="Photo Viewer" Tag="PhotoViewer">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Pictures"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="TV" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Video"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="BBC iPlayer" Tag="BBCiPlayer">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Video"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="My5" Tag="My5">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Video"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <NavigationViewItem Content="Films" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Video"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>

                        <NavigationViewItem Content="Netflix" Tag="Netflix">
                            <NavigationViewItem.Icon>
                                <BitmapIcon UriSource="ms-appx:///Assets/Sidebar/netflix.png"
                                            ShowAsMonochrome="False"
                                            Width="40" Height="40"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Amazon Prime Video" Tag="PrimeVideo">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Video"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Disney+" Tag="DisneyPlus">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Video"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Paramount+" Tag="ParamountPlus">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Video"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Now TV" Tag="NowTV">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Video"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <NavigationViewItem Content="Gaming" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7FC;"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Xbox" Tag="Xbox">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE7FC;"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="GeForce NOW" Tag="GeForceNow">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Amazon Luna" Tag="AmazonLuna">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Boosteroid" Tag="Boosteroid">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Shadow PC" Tag="ShadowPC">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <NavigationViewItem Content="Zink Social" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="People"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>

                        <NavigationViewItem Content="Login" Tag="SocialLogin">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="ContactInfo"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Register" Tag="SocialRegister">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="AddFriend"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Friends" Tag="SocialFriends">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="People"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Friend Requests" Tag="SocialFriendRequests">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Mail"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Profile" Tag="SocialProfile">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Contact"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Call" Tag="SocialCall">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Phone"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <NavigationViewItem Content="Social" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Contact"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>

                        <NavigationViewItem Content="Twitch" Tag="Twitch">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Video"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Discord" Tag="Discord">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Message"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="YouTube" Tag="YouTube">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="TikTok" Tag="TikTok">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Video"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Instagram" Tag="Instagram">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Camera"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="X" Tag="X">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Facebook" Tag="Facebook">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Contact"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Telegram Web" Tag="Telegram">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Message"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="WhatsApp Web" Tag="WhatsApp">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Message"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Messenger" Tag="Messenger">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Message"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="LinkedIn" Tag="LinkedIn">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Contact"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Threads" Tag="Threads">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Bluesky" Tag="Bluesky">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Mastodon" Tag="Mastodon">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Pinterest" Tag="Pinterest">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Tumblr" Tag="Tumblr">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem Content="Reddit" Tag="Reddit">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <NavigationViewItem Content="Voice + 4K Share" Tag="nativevoiceshare">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Video"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Notifications" Tag="Notifications">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Message"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Feedback" Tag="Feedback">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Emoji2"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Privacy Policy" Tag="PrivacyPolicy">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ContactInfo"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Leave a review" Tag="LeaveReview">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Like"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="App customisation" Tag="AppCustomization">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Edit"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="About" Tag="About">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Help"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
        </NavigationView>

        <Frame
            x:Name="ContentFrame"
            x:FieldModifier="public"
            Grid.Column="1"
            Background="Transparent"/>
    </Grid>
</Window>