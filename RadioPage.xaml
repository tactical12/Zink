<Page
    x:Class="Zink.RadioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Zink"
    Background="Black">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20" Spacing="20">
            <TextBlock Text="Select a Radio Station"
                       FontSize="28"
                       Foreground="White"
                       HorizontalAlignment="Center" />

            <ItemsControl ItemsSource="{x:Bind AllStationsOrdered, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Click="PlayStation_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="8"
                                Tag="{Binding}">
                            <StackPanel Width="140">
                                <Border Background="White"
                                        CornerRadius="10"
                                        Padding="4">
                                    <Image Source="{Binding Image}"
                                           Height="80"
                                           Stretch="Uniform" />
                                </Border>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="White"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ProgressRing x:Name="LoadingRing"
                          IsActive="False"
                          Visibility="Collapsed"
                          Foreground="White"
                          Height="40"
                          Width="40"
                          HorizontalAlignment="Center" />

            <Border Background="#222"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,20,0,0">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Image x:Name="NowPlayingImage"
                               Width="80"
                               Height="80"
                               Stretch="Uniform" />
                        <StackPanel>
                            <TextBlock Text="Now Playing:"
                                       Foreground="Gray"
                                       FontSize="14" />
                            <TextBlock x:Name="NowPlayingText"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="CurrentStationText"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Opacity="0.9"
                                       Foreground="White"
                                       Text="The now playing station: —"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Volume"
                                   Foreground="White"
                                   FontSize="14" />
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE992;"
                                      Foreground="White"/>
                            <Slider x:Name="VolumeSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="100"
                                    Width="260"
                                    ValueChanged="VolumeSlider_ValueChanged" />
                            <TextBlock x:Name="VolumeText"
                                       Text="100%"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Stop"
                                Click="Stop_Click"
                                Width="80"/>

                        <Button x:Name="LikeSongButton"
                                Click="LikeSongButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE00B;"/>
                                <TextBlock Text="Like song"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="EnableBackgroundButton"
                                Click="EnableBackgroundButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7C3;"/>
                                <TextBlock Text="play the current station in the background of this app"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Content="Play with mini player"
                    Margin="8,0,0,0"
                    Click="OpenMiniPlayer_Click"/>

            <MediaPlayerElement x:Name="Player"
                                AreTransportControlsEnabled="False"
                                Width="0"
                                Height="0" />
        </StackPanel>
    </ScrollViewer>
</Page>