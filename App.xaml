<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Zink.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Zink"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:Zink">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Use your custom BooleanToVisibilityConverter -->
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <SolidColorBrush x:Key="ZinkGlassPanelBrush" Color="#AA3F6F7F"/>
            <SolidColorBrush x:Key="ZinkGlassCardBrush" Color="#823F6F7F"/>
            <SolidColorBrush x:Key="ZinkGlassBorderBrush" Color="#48A5CFDF"/>
            <SolidColorBrush x:Key="ZinkGlassHoverBrush" Color="#2C76A6B6"/>
            <SolidColorBrush x:Key="ZinkGlassSelectedBrush" Color="#4492C4D4"/>

            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
