<Page
    x:Class="Zink.VideoPlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:mediaX="using:Microsoft.UI.Xaml.Media"
    xmlns:local="using:Zink"
    RequestedTheme="Dark"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    PointerMoved="Page_PointerMoved">

    <Page.Resources>
        <mediaX:AcrylicBrush
            x:Key="ControlPanelBackground"
            TintColor="{ThemeResource SystemAccentColor}"
            TintOpacity="0.10"
            FallbackColor="{ThemeResource SystemChromeLowColor}"
            AlwaysUseFallback="False" />

        <local:SecondsToTimeConverter x:Key="SecondsToTimeConverter" />
    </Page.Resources>

    <Grid>
        <controls:MediaPlayerElement
            x:Name="mediaPlayerElement"
            AreTransportControlsEnabled="False"
            AutoPlay="False"
            Stretch="Uniform" />

        <Border
            x:Name="SubtitleOverlay"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="20,0,20,80"
            Background="#66000000"
            CornerRadius="6"
            Padding="10"
            Visibility="Collapsed">

            <TextBlock
                x:Name="SubtitleTextBlock"
                Text=""
                Foreground="White"
                FontSize="24"
                TextWrapping="WrapWholeWords"
                TextAlignment="Center"
                MaxWidth="1100" />
        </Border>

        <Border
            x:Name="ControlPanel"
            Background="{StaticResource ControlPanelBackground}"
            CornerRadius="12"
            Padding="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,20"
            Width="1180"
            MaxWidth="1180">

            <StackPanel
                Spacing="10"
                HorizontalAlignment="Center">

                <Grid Width="1120" MaxWidth="1120">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="CurrentTimeText"
                        Text="00:00"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0" />

                    <Slider
                        x:Name="SeekSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="1"
                        Value="0"
                        IsEnabled="False"
                        IsThumbToolTipEnabled="True"
                        ThumbToolTipValueConverter="{StaticResource SecondsToTimeConverter}"
                        ValueChanged="SeekSlider_ValueChanged"
                        VerticalAlignment="Center" />

                    <TextBlock
                        x:Name="TotalTimeText"
                        Grid.Column="2"
                        Text="00:00"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0" />
                </Grid>

                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="46">

                    <Button
                        Click="Rewind_Click"
                        Content="Rewind" />

                    <Button
                        Click="Play_Click"
                        Style="{ThemeResource AccentButtonStyle}">
                        <TextBlock Text="Play" />
                    </Button>

                    <Button
                        Click="Pause_Click"
                        Content="Pause" />

                    <Button
                        Click="Forward_Click"
                        Content="Forward" />

                    <Button
                        x:Name="FullScreenButton"
                        Click="FullScreenButton_Click">
                        <TextBlock
                            x:Name="FullScreenLabel"
                            Text="Fullscreen" />
                    </Button>

                    <Button
                        Click="Browse_Click"
                        Content="Browse files" />

                    <Button
                        x:Name="SubtitlesButton"
                        Click="SubtitlesButton_Click">
                        <TextBlock
                            x:Name="SubtitlesButtonLabel"
                            Text="Subtitles" />
                    </Button>

                    <Button
                        x:Name="SoundButton"
                        Content="Sound" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>