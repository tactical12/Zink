<Window
    x:Class="Zink.SpotifyWidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <!-- Put visual styling on the root container, not on <Window> -->
    <Grid x:Name="Root" Background="#202020" Padding="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Album Art -->
        <Border Width="120" Height="120" CornerRadius="12" Background="#303030">
            <Image x:Name="AlbumArtImage" Stretch="UniformToFill"/>
        </Border>

        <!-- Track Info + Controls -->
        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center" Spacing="12">
            <!-- Song Info -->
            <TextBlock x:Name="TrackTitle" Text="Track" FontSize="22" FontWeight="Bold"
                       Foreground="White" TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="TrackArtist" Text="Artist" FontSize="16"
                       Foreground="#DDDDDD" TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="AlbumName" Text="Album" FontSize="14"
                       Foreground="#AAAAAA" TextTrimming="CharacterEllipsis"/>

            <!-- Progress row kept for compatibility but hidden -->
            <StackPanel x:Name="ProgressRow" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10" Visibility="Collapsed">
                <TextBlock x:Name="ElapsedText" Text="0:00" Foreground="White" FontSize="12"/>
                <Slider x:Name="ProgressSlider"
                        Minimum="0"
                        Maximum="100"
                        Value="0"
                        Width="420"
                        PointerPressed="ProgressSlider_PointerPressed"
                        PointerReleased="ProgressSlider_PointerReleased"
                        PointerCaptureLost="ProgressSlider_PointerReleased"/>
                <TextBlock x:Name="RemainingText" Text="-0:00" Foreground="White" FontSize="12"/>
            </StackPanel>

            <!-- Single-line timer -->
            <TextBlock x:Name="TimerText"
                       Text="0:00 / 0:00"
                       Foreground="White"
                       FontSize="12"
                       Opacity="0.9"/>

            <!-- Controls -->
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <Button Click="Prev_Click">
                    <FontIcon Glyph="&#xE892;" Foreground="White"/>
                </Button>
                <Button Click="PlayPause_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" Foreground="White"/>
                        <TextBlock x:Name="PlayPauseLabel" Text="Play" Foreground="White"/>
                    </StackPanel>
                </Button>
                <Button Click="Next_Click">
                    <FontIcon Glyph="&#xE893;" Foreground="White"/>
                </Button>

                <Button x:Name="LikeButton" Click="Like_Click" ToolTipService.ToolTip="Like">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon x:Name="LikeIcon" Glyph="&#xEB52;" Foreground="White"/>
                        <TextBlock x:Name="LikeLabel" Text="Like" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Click="Hide_Click">
                    <FontIcon Glyph="&#xE8BB;" Foreground="White"/>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- ? Hidden WebView2 host so code-behind can reference SpotifyWebView -->
        <controls:WebView2 x:Name="SpotifyWebView"
                           Visibility="Collapsed"
                           IsHitTestVisible="False" />
    </Grid>
</Window>
