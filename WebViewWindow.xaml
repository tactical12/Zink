<Page
    x:Class="Zink.WebViewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Zink"
    xmlns:wv2="using:Microsoft.UI.Xaml.Controls"
    Background="Black">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <TextBlock x:Name="StreamTitle"
                       Text="Loading..."
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>

            <!-- This is hidden by default via code-behind size (1x1),
                 but large enough to show login screen if needed -->
            <wv2:WebView2 x:Name="RadioWebView"
                         Width="1000"
                         Height="700"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
