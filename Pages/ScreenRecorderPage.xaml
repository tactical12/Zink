<Page
    x:Class="Zink.Pages.ScreenRecorderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">

            <StackPanel Spacing="6">
                <TextBlock Text="Screen Recorder"
                           FontSize="30"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Record screen/window to MP4"
                           Opacity="0.75"/>
            </StackPanel>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Status"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusText" Text="Idle"/>
                    <TextBlock x:Name="TargetText" Text="No capture target selected."/>
                    <TextBlock x:Name="ManualStateText" Text="Manual recording: Stopped"/>
                    <TextBlock x:Name="BackgroundStateText" Text="Background clipping: Stopped"/>
                    <TextBlock Text="Hotkey: Shift + R"/>
                </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Capture Target"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <Button x:Name="PickSourceButton"
                            Content="Pick Screen / Window"
                            Click="PickSourceButton_Click"/>
                </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Audio"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <ToggleSwitch x:Name="IncludeSystemAudioToggle"
                                  Header="Include system audio"
                                  IsOn="True"/>

                    <ComboBox x:Name="RenderDevicesComboBox"
                              Header="Sound source"
                              DisplayMemberPath="Name"/>

                    <ToggleSwitch x:Name="IncludeMicrophoneToggle"
                                  Header="Include microphone"
                                  IsOn="False"/>

                    <ComboBox x:Name="MicDevicesComboBox"
                              Header="Microphone"
                              DisplayMemberPath="Name"/>
                </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Manual Recording"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <Button x:Name="StartRecordingButton"
                            Content="Start Recording"
                            Click="StartRecordingButton_Click"/>
                    <Button x:Name="StopRecordingButton"
                            Content="Stop Recording"
                            Click="StopRecordingButton_Click"/>
                </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Background Clipping"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <Button x:Name="StartBackgroundButton"
                            Content="Start background clipping"
                            Click="StartBackgroundButton_Click"/>
                    <Button x:Name="StopBackgroundButton"
                            Content="Stop background clipping"
                            Click="StopBackgroundButton_Click"/>
                    <Button x:Name="SaveLast45SecondsButton"
                            Content="Save last 45 seconds now"
                            Click="SaveLast45SecondsButton_Click"/>
                    <ToggleSwitch x:Name="RunAtStartupToggle"
                                  Header="Run at sign-in"
                                  Toggled="RunAtStartupToggle_Toggled"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>