<Page
    x:Class="Zink.Pages.ScreenRecorderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF071017">

    <Page.Resources>
        <LinearGradientBrush x:Key="RecorderSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF061017" Offset="0"/>
            <GradientStop Color="#FF163642" Offset="0.45"/>
            <GradientStop Color="#FF161923" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="GlassPanelBrush" Color="#36FFFFFF"/>
        <SolidColorBrush x:Key="GlassPanelStrongBrush" Color="#52FFFFFF"/>
        <SolidColorBrush x:Key="GlassStrokeBrush" Color="#50FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B8FFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#78FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF42D7B5"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FFFF5264"/>
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#3042D7B5"/>
        <SolidColorBrush x:Key="SoftDangerBrush" Color="#38FF5264"/>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource GlassPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassStrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource RecorderSurfaceBrush}" Padding="22" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="Zink Recorder"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="30"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Ready when you are."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <Border x:Name="LiveRecordingPill"
                        Padding="12,7"
                        CornerRadius="999"
                        Background="{StaticResource SoftDangerBrush}"
                        BorderBrush="#A0FF8A92"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="9" Height="9" Fill="{StaticResource DangerBrush}"/>
                        <TextBlock Text="Recording your screen"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Padding="10,7"
                        CornerRadius="999"
                        Background="{StaticResource SoftAccentBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE7F4;"
                                  FontSize="14"
                                  Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Native"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource GlassCardStyle}"
                    Background="{StaticResource GlassPanelStrongBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="52"
                                Height="52"
                                CornerRadius="16"
                                Background="{StaticResource SoftAccentBrush}">
                            <FontIcon Glyph="&#xE8B7;"
                                      FontSize="24"
                                      Foreground="{StaticResource AccentBrush}"/>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusText"
                                       Text="Idle"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="TargetText"
                                       Text="No capture target selected."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.78*"/>
                        </Grid.ColumnDefinitions>

                        <Border CornerRadius="12"
                                Padding="12"
                                Background="#22FFFFFF">
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Manual"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock x:Name="ManualStateText"
                                           Text="Manual recording: Stopped"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                CornerRadius="12"
                                Padding="12"
                                Background="#22FFFFFF">
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Replay"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock x:Name="BackgroundStateText"
                                           Text="Background clipping: Stopped"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                CornerRadius="12"
                                Padding="12"
                                Background="#1D42D7B5">
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Hotkey"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="Shift + R"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PickSourceButton"
                                Click="PickSourceButton_Click"
                                HorizontalAlignment="Stretch"
                                Padding="12,10"
                                Background="{StaticResource AccentBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE8B7;" FontSize="15"/>
                                <TextBlock Text="Source" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="StartRecordingButton"
                                Grid.Column="1"
                                Click="StartRecordingButton_Click"
                                HorizontalAlignment="Stretch"
                                Padding="12,10"
                                Background="{StaticResource SoftAccentBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE768;" FontSize="15"/>
                                <TextBlock Text="Record" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="StopRecordingButton"
                                Grid.Column="2"
                                Click="StopRecordingButton_Click"
                                HorizontalAlignment="Stretch"
                                Padding="12,10"
                                Background="{StaticResource DangerBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE71A;" FontSize="15"/>
                                <TextBlock Text="Stop" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.ColumnSpan="2"
                               Text="Audio"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <ToggleSwitch x:Name="IncludeSystemAudioToggle"
                                  Grid.Row="1"
                                  Header="System"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  IsOn="True"/>

                    <ToggleSwitch x:Name="IncludeMicrophoneToggle"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Header="Mic"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  IsOn="False"/>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="8">
                        <ComboBox x:Name="RenderDevicesComboBox"
                                  Header="Output"
                                  DisplayMemberPath="Name"
                                  HorizontalAlignment="Stretch"/>
                        <ComboBox x:Name="MicDevicesComboBox"
                                  Header="Input"
                                  DisplayMemberPath="Name"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource GlassCardStyle}"
                    Padding="14,12"
                    Background="#42FFFFFF">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Instant Replay"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="45 seconds"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>

                    <ToggleSwitch x:Name="RunAtStartupToggle"
                                  Grid.Column="1"
                                  Header="At sign-in"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Toggled="RunAtStartupToggle_Toggled"
                                  VerticalAlignment="Center"/>

                    <Button x:Name="StartBackgroundButton"
                            Grid.Column="2"
                            Click="StartBackgroundButton_Click"
                            Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE7C8;" FontSize="15"/>
                            <TextBlock Text="Start" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="StopBackgroundButton"
                            Grid.Column="3"
                            Click="StopBackgroundButton_Click"
                            Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE711;" FontSize="15"/>
                            <TextBlock Text="Stop" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SaveLast45SecondsButton"
                            Grid.Column="4"
                            Click="SaveLast45SecondsButton_Click"
                            Padding="14,10"
                            Background="{StaticResource AccentBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="15"/>
                            <TextBlock Text="Save 45s" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Zink capture"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Border Grid.Column="1"
                    Padding="10,6"
                    CornerRadius="999"
                    Background="#20FFFFFF">
                <TextBlock Text="Clean"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </Border>
            <Border Grid.Column="2"
                    Padding="10,6"
                    CornerRadius="999"
                    Background="#20FFFFFF">
                <TextBlock Text="Native"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>
    </Grid>
</Page>
