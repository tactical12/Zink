<Page
    x:Class="Zink.Pages.PhotoViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="Photo Viewer" FontSize="28" FontWeight="SemiBold"/>
            <Button Content="Open Photos" Click="OpenPhotos_Click"/>
            <Button Content="Clear" Click="Clear_Click"/>
            <TextBlock x:Name="StatusText" Margin="12,6,0,0" Opacity="0.8"/>
        </StackPanel>

        <!-- Body -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Thumbnails -->
            <Border CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <GridView x:Name="ThumbsGrid"
                              IsItemClickEnabled="True"
                              ItemClick="ThumbsGrid_ItemClick"
                              SelectionMode="Single"
                              ItemsSource="{x:Bind Photos, Mode=OneWay}"
                              Padding="12">
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}"
                                               Width="300"
                                               Height="170"
                                               Stretch="UniformToFill"
                                               HorizontalAlignment="Center"/>
                                        <Border Background="#80000000" VerticalAlignment="Bottom" Padding="10">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>
            </Border>

            <!-- Preview -->
            <Border Grid.Column="1"
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Image x:Name="PreviewImage" Stretch="Uniform"/>
                    <TextBlock x:Name="EmptyPreviewText"
                               Text="Pick some photos to start"
                               FontSize="18"
                               Opacity="0.7"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
