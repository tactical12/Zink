<Page
    x:Class="Zink.Pages.Social.FriendRequestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*">
        <TextBlock Text="Friend Requests" FontSize="28" FontWeight="SemiBold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12,0,12">
            <Button Content="Refresh" Click="RefreshButton_Click"/>
            <Button Content="Back" Click="BackButton_Click"/>
        </StackPanel>

        <ListView Grid.Row="2" x:Name="RequestsList" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,6">
                        <StackPanel>
                            <TextBlock Text="{Binding FromUsername}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding FromDisplayName}" Opacity="0.8"/>
                            <TextBlock Text="{Binding CreatedUtc}" Opacity="0.6"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Accept" Tag="{Binding RequestId}" Click="AcceptButton_Click" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Content="Decline" Tag="{Binding RequestId}" Click="DeclineButton_Click" Margin="8,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>