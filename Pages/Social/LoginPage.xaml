<Page
    x:Class="Zink.Pages.Social.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24">
            <StackPanel Spacing="12" MaxWidth="420">
                <TextBlock Text="Login" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="Email or Username"/>
                <TextBox x:Name="EmailOrUsernameBox" PlaceholderText="Email or username"/>

                <TextBlock Text="Password"/>
                <PasswordBox x:Name="PasswordBox"/>

                <Button Content="Login" Click="LoginButton_Click"/>
                <Button Content="Go to Register" Click="RegisterButton_Click"/>

                <ProgressRing x:Name="BusyRing" IsActive="False" Visibility="Collapsed"/>
                <TextBlock x:Name="StatusText" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>