<Page
    x:Class="Zink.Pages.Social.FriendsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="GlassPanelBrush" Color="#B0141820"/>
        <SolidColorBrush x:Key="GlassPanelBorderBrush" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="GlassCardBrush" Color="#9A10141B"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AFC5CFD8"/>

        <Style x:Key="GlassCommandButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CornerRadius" Value="21"/>
            <Setter Property="Background" Value="#3AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#32FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="RoundIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="21"/>
            <Setter Property="Background" Value="#2EFFFFFF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#101821" Offset="0"/>
                <GradientStop Color="#151B24" Offset="0.45"/>
                <GradientStop Color="#0B0D12" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Padding="28" RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="22"
                        CornerRadius="24"
                        Background="{StaticResource GlassPanelBrush}"
                        BorderBrush="{StaticResource GlassPanelBorderBrush}"
                        BorderThickness="1">
                    <Grid ColumnSpacing="18" RowSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Friends"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="Find people, start calls, and manage your Zink circle."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource RoundIconButtonStyle}"
                                    Click="RefreshFriendsButton_Click"
                                    ToolTipService.ToolTip="Refresh friends">
                                <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource GlassCommandButtonStyle}"
                                    Click="FriendRequestsButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8FA;" FontSize="15"/>
                                    <TextBlock Text="Requests" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RoundIconButtonStyle}"
                                    Click="ProfileButton_Click"
                                    ToolTipService.ToolTip="Profile">
                                <FontIcon Glyph="&#xE77B;" FontSize="16"/>
                            </Button>
                        </StackPanel>

                        <Grid Grid.Row="1"
                              Grid.ColumnSpan="2"
                              ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SearchBox"
                                     MinWidth="260"
                                     Height="44"
                                     CornerRadius="22"
                                     PlaceholderText="Search username or display name..."/>

                            <Button Grid.Column="1"
                                    Style="{StaticResource GlassCommandButtonStyle}"
                                    Click="SearchButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE721;" FontSize="15"/>
                                    <TextBlock Text="Search" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="14,10"
                        CornerRadius="18"
                        Background="#241D2732"
                        BorderBrush="#24FFFFFF"
                        BorderThickness="1">
                    <TextBlock x:Name="StatusText"
                               TextWrapping="Wrap"
                               Foreground="#FFFF9C9C"
                               FontSize="13"/>
                </Border>

                <Grid Grid.Row="2" ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.95*"/>
                        <ColumnDefinition Width="1.25*"/>
                    </Grid.ColumnDefinitions>

                    <Border Padding="18"
                            CornerRadius="24"
                            Background="{StaticResource GlassPanelBrush}"
                            BorderBrush="{StaticResource GlassPanelBorderBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Friend hub"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="Quick totals and social shortcuts."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Spacing="12">
                                <Grid ColumnSpacing="10" RowSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Padding="14"
                                            CornerRadius="18"
                                            Background="{StaticResource GlassCardBrush}"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <StackPanel Spacing="3">
                                            <TextBlock x:Name="TotalFriendsCountText"
                                                       Text="0"
                                                       FontSize="28"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="Friends"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Padding="14"
                                            CornerRadius="18"
                                            Background="{StaticResource GlassCardBrush}"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <StackPanel Spacing="3">
                                            <TextBlock x:Name="OnlineFriendsCountText"
                                                       Text="0"
                                                       FontSize="28"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF75F0A0"/>
                                            <TextBlock Text="Online"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Padding="14"
                                            CornerRadius="18"
                                            Background="{StaticResource GlassCardBrush}"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <StackPanel Spacing="3">
                                            <TextBlock x:Name="AwayFriendsCountText"
                                                       Text="0"
                                                       FontSize="28"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFFFD56B"/>
                                            <TextBlock Text="Away"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Grid.Column="1"
                                            Padding="14"
                                            CornerRadius="18"
                                            Background="{StaticResource GlassCardBrush}"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <StackPanel Spacing="3">
                                            <TextBlock x:Name="BusyFriendsCountText"
                                                       Text="0"
                                                       FontSize="28"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFFF7777"/>
                                            <TextBlock Text="Busy"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Padding="16"
                                        CornerRadius="18"
                                        Background="#261E2631"
                                        BorderBrush="#24FFFFFF"
                                        BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Start from a friend"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Use the buttons beside each friend to message, call, share screen, or block."
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="18"
                            CornerRadius="24"
                            Background="{StaticResource GlassPanelBrush}"
                            BorderBrush="{StaticResource GlassPanelBorderBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="My friends"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="Message, call, screen share, and see live status."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"/>
                            </StackPanel>

                            <ListView x:Name="FriendsList"
                                      Grid.Row="1"
                                      SelectionMode="None"
                                      Background="Transparent"
                                      BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="14"
                                                CornerRadius="18"
                                                Background="{StaticResource GlassCardBrush}"
                                                BorderBrush="#24FFFFFF"
                                                BorderThickness="1">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Width="46" Height="46">
                                                    <Ellipse Fill="#243342"/>
                                                    <FontIcon Glyph="&#xE77B;"
                                                              FontSize="18"
                                                              Foreground="White"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Grid>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Spacing="2">
                                                    <TextBlock Text="{Binding Username}"
                                                               Foreground="White"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{Binding PresenceDetail}"
                                                               Foreground="#86C5CFD8"
                                                               FontSize="11"/>
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        MinWidth="102"
                                                        Padding="10,5"
                                                        CornerRadius="13"
                                                        Background="#26FFFFFF"
                                                        BorderBrush="#22FFFFFF"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="7"
                                                                HorizontalAlignment="Center">
                                                        <Ellipse Width="8"
                                                                 Height="8"
                                                                 Fill="{Binding PresenceBrush}"
                                                                 VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding PresenceText}"
                                                                   Foreground="White"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>

                                                <Button Grid.Column="3"
                                                        Style="{StaticResource RoundIconButtonStyle}"
                                                        Tag="{Binding UserId}"
                                                        Click="MessageButton_Click"
                                                        ToolTipService.ToolTip="Message">
                                                    <FontIcon Glyph="&#xE8BD;" FontSize="16"/>
                                                </Button>

                                                <Button Grid.Column="4"
                                                        Style="{StaticResource RoundIconButtonStyle}"
                                                        Tag="{Binding UserId}"
                                                        Click="VoiceCallButton_Click"
                                                        ToolTipService.ToolTip="Voice call">
                                                    <FontIcon Glyph="&#xE717;" FontSize="16"/>
                                                </Button>

                                                <Button Grid.Column="5"
                                                        Style="{StaticResource RoundIconButtonStyle}"
                                                        Tag="{Binding UserId}"
                                                        Click="ShareScreenButton_Click"
                                                        ToolTipService.ToolTip="Share screen">
                                                    <FontIcon Glyph="&#xE714;" FontSize="16"/>
                                                </Button>

                                                <Button Grid.Column="6"
                                                        Style="{StaticResource RoundIconButtonStyle}"
                                                        Tag="{Binding UserId}"
                                                        Click="BlockButton_Click"
                                                        ToolTipService.ToolTip="Block">
                                                    <FontIcon Glyph="&#xE8F8;" FontSize="16"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
