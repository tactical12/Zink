<Page
    x:Class="Zink.Pages.Social.FriendsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">

            <TextBlock Text="Friends"
                       FontSize="32"
                       FontWeight="SemiBold"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="SearchBox"
                         Width="280"
                         PlaceholderText="Search username or display name..."/>

                <Button Content="Search"
                        Click="SearchButton_Click"/>

                <Button Content="Refresh Friends"
                        Click="RefreshFriendsButton_Click"/>

                <Button Content="Friend Requests"
                        Click="FriendRequestsButton_Click"/>

                <Button Content="Profile"
                        Click="ProfileButton_Click"/>
            </StackPanel>

            <TextBlock x:Name="StatusText"
                       TextWrapping="Wrap"
                       Foreground="IndianRed"/>

            <StackPanel Spacing="8">
                <TextBlock Text="Search Results"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <ListView x:Name="SearchResultsList"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding Username}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Opacity="0.8"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Content="Add Friend"
                                        Tag="{Binding Username}"
                                        Click="AddFriendButton_Click"/>

                                <Button Grid.Column="2"
                                        Margin="8,0,0,0"
                                        Content="Block"
                                        Tag="{Binding UserId}"
                                        Click="BlockButton_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel Spacing="8" Margin="0,16,0,0">
                <TextBlock Text="My Friends"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <ListView x:Name="FriendsList"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding Username}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Opacity="0.8"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Content="Voice Call"
                                        Tag="{Binding UserId}"
                                        Click="VoiceCallButton_Click"/>

                                <Button Grid.Column="2"
                                        Margin="8,0,0,0"
                                        Content="Share Screen"
                                        Tag="{Binding UserId}"
                                        Click="ShareScreenButton_Click"/>

                                <Button Grid.Column="3"
                                        Margin="8,0,0,0"
                                        Content="Block"
                                        Tag="{Binding UserId}"
                                        Click="BlockButton_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>