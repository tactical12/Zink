<Page
    x:Class="Zink.Pages.Social.RegisterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24">
            <StackPanel Spacing="12" MaxWidth="420">
                <TextBlock Text="Register" FontSize="28" FontWeight="SemiBold"/>

                <TextBlock Text="Display Name"/>
                <TextBox x:Name="DisplayNameBox" PlaceholderText="Display name"/>

                <TextBlock Text="Username"/>
                <TextBox x:Name="UsernameBox" PlaceholderText="Username"/>

                <TextBlock Text="Email"/>
                <TextBox x:Name="EmailBox" PlaceholderText="Email"/>

                <TextBlock Text="Password"/>
                <PasswordBox x:Name="PasswordBox"/>

                <Button Content="Create Account" Click="RegisterButton_Click"/>
                <Button Content="Back to Login" Click="LoginButton_Click"/>

                <ProgressRing x:Name="BusyRing" IsActive="False" Visibility="Collapsed"/>
                <TextBlock x:Name="StatusText" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>