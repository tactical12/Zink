<Page
    x:Class="Zink.Pages.Social.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Text="Profile" FontSize="28" FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1" x:Name="EmailText" Margin="0,12,0,0"/>
        <TextBlock Grid.Row="2" x:Name="UsernameText" Margin="0,8,0,0"/>
        <TextBlock Grid.Row="3" Text="Display Name" Margin="0,12,0,4"/>
        <TextBox Grid.Row="4" x:Name="DisplayNameBox"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="Save" Click="SaveButton_Click"/>
            <Button Content="Logout" Click="LogoutButton_Click"/>
            <Button Content="Back" Click="BackButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="6" x:Name="StatusText" Margin="0,12,0,0" TextWrapping="Wrap"/>
    </Grid>
</Page>