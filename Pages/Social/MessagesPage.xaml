<Page
    x:Class="Zink.Pages.Social.MessagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="GlassPanelBrush" Color="#B0141820"/>
        <SolidColorBrush x:Key="GlassPanelBorderBrush" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="GlassCardBrush" Color="#9A10141B"/>
        <SolidColorBrush x:Key="GlassCardHoverBrush" Color="#C2182430"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AFC5CFD8"/>
        <SolidColorBrush x:Key="AccentTextBrush" Color="#FF7FDBFF"/>

        <Style x:Key="RoundIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Background" Value="#2EFFFFFF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Background" Value="#2EFFFFFF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#101820" Offset="0"/>
                <GradientStop Color="#172431" Offset="0.5"/>
                <GradientStop Color="#080B10" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Padding="28" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Padding="22"
                    CornerRadius="24"
                    Background="{StaticResource GlassPanelBrush}"
                    BorderBrush="{StaticResource GlassPanelBorderBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Width="58" Height="58">
                        <Ellipse Fill="#273543"/>
                        <FontIcon Glyph="&#xE8BD;"
                                  FontSize="24"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="4">
                        <TextBlock x:Name="ThreadTitleText"
                                   Text="Messages"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="ThreadSubtitleText"
                                   Text="Saved conversations stay on this device."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="14"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Style="{StaticResource RoundIconButtonStyle}"
                            Click="BackButton_Click"
                            ToolTipService.ToolTip="Back">
                        <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Padding="18"
                        CornerRadius="24"
                        Background="{StaticResource GlassPanelBrush}"
                        BorderBrush="{StaticResource GlassPanelBorderBrush}"
                        BorderThickness="1">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Inbox"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock x:Name="InboxSummaryText"
                                       Text="No saved messages yet"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"/>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Padding="14"
                                CornerRadius="18"
                                Background="{StaticResource GlassCardBrush}"
                                BorderBrush="#24FFFFFF"
                                BorderThickness="1">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="New message"
                                           Foreground="White"
                                           FontWeight="SemiBold"/>

                                <Grid Grid.Row="1"
                                      ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="FriendPickerBox"
                                              MinHeight="42"
                                              PlaceholderText="Choose a friend"
                                              DisplayMemberPath="Label"
                                              HorizontalAlignment="Stretch"/>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource RoundIconButtonStyle}"
                                            Click="StartNewMessageButton_Click"
                                            ToolTipService.ToolTip="Start message">
                                        <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                        <ListView x:Name="ConversationList"
                                  Grid.Row="2"
                                  SelectionMode="Single"
                                  SelectionChanged="ConversationList_SelectionChanged"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14"
                                            Margin="0,0,0,8"
                                            CornerRadius="18"
                                            Background="{StaticResource GlassCardBrush}"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <Grid RowSpacing="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Subtitle}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TimestampText}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       Margin="10,2,0,0"/>

                                            <TextBlock Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Text="{Binding Preview}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="StatusText"
                                   Grid.Row="3"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Padding="18"
                        CornerRadius="24"
                        Background="{StaticResource GlassPanelBrush}"
                        BorderBrush="{StaticResource GlassPanelBorderBrush}"
                        BorderThickness="1">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="48" Height="48">
                                <Ellipse Fill="#263241"/>
                                <TextBlock x:Name="ActiveAvatarText"
                                           Text="Z"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                <TextBlock x:Name="InboxNameText"
                                           Text="No active thread"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="InboxPreviewText"
                                           Text="Choose a saved conversation or start a new one."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="MessagesPanel"
                                        Spacing="10">
                                <Border Padding="14"
                                        CornerRadius="18"
                                        Background="{StaticResource GlassCardBrush}"
                                        BorderBrush="#24FFFFFF"
                                        BorderThickness="1"
                                        HorizontalAlignment="Left"
                                        MaxWidth="540">
                                    <TextBlock x:Name="EmptyThreadText"
                                               Text="Messages will appear here."
                                               Foreground="White"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Row="2"
                              ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="MessageBox"
                                     MinHeight="46"
                                     CornerRadius="23"
                                     PlaceholderText="Message..."
                                     TextWrapping="Wrap"
                                     IsEnabled="False"/>

                            <Button x:Name="SendButton"
                                    Grid.Column="1"
                                    Style="{StaticResource RoundIconButtonStyle}"
                                    Click="SendButton_Click"
                                    IsEnabled="False"
                                    ToolTipService.ToolTip="Send">
                                <FontIcon Glyph="&#xE724;" FontSize="16"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
