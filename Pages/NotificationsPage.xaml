<Page
    x:Class="Zink.Pages.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:Zink.Services">

    <StackPanel Padding="20" Spacing="12">
        <TextBlock Text="Notification Center" 
                   FontSize="24" 
                   FontWeight="SemiBold"/>

        <!-- example button to fire a toast -->
        <Button Content="Send Test Notification"
                Click="OnSendTestNotificationClicked"/>
    </StackPanel>
</Page>
