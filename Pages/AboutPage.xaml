<Page
    x:Class="Zink.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Zink.Pages"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="40,30">
        <StackPanel Spacing="20">
            <TextBlock Text="About Zink" FontSize="28" FontWeight="Bold"/>

            <!-- Version 2.4.1.0 Row (NEW) -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Version 2.4.1.0" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="LearnMore241Button"
                        Content="Learn More"
                        Click="LearnMore241Button_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Version 2.3.5.1 Row (NEW) -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Version 2.3.5.0" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="LearnMore235Button"
                        Content="Learn More"
                        Click="LearnMore235Button_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Version 2.2.8 Row (NEW) -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Version 2.2.8.0" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="LearnMore224Button"
                        Content="Learn More"
                        Click="LearnMore224Button_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Version 2.1.6 Row -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Version 2.1.6.0" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="LearnMore216Button"
                        Content="Learn More"
                        Click="LearnMore216Button_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Version 2.1.5 Row -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Version 2.1.5.0" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="LearnMore21Button"
                        Content="Learn More"
                        Click="LearnMore21Button_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Version 2.0 Row -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Version 2.0.0.0" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="LearnMore20Button"
                        Content="Learn More"
                        Click="LearnMore20Button_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Version 1.0 Row -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Version 1.0.0.0" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="LearnMore10Button"
                        Content="Learn More"
                        Click="LearnMore10Button_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- App info -->
            <TextBlock x:Name="VersionText" FontSize="18"/>
            <TextBlock x:Name="BuildTimeText" FontSize="18"/>
            <TextBlock Text="Zink is a media, gaming, and social app platform."
                       FontSize="16"
                       TextWrapping="WrapWholeWords"/>
            <TextBlock Text="The Zink app was made by Francis Hayle. Copyright 2026."
                       FontSize="18"/>
        </StackPanel>
    </Grid>
</Page>
