<Page
    x:Class="Zink.Pages.HomeDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Resources>
        <AcrylicBrush x:Key="GlassPanelBrush"
                      TintColor="#111820"
                      TintOpacity="0.72"
                      TintLuminosityOpacity="0.50"
                      FallbackColor="#D1111820"/>
        <AcrylicBrush x:Key="GlassStrongBrush"
                      TintColor="#0B1219"
                      TintOpacity="0.88"
                      TintLuminosityOpacity="0.42"
                      FallbackColor="#EB0B1219"/>
        <SolidColorBrush x:Key="GlassTileBrush" Color="#66131D28"/>
        <SolidColorBrush x:Key="GlassTileHoverBrush" Color="#8A1C2A38"/>
        <SolidColorBrush x:Key="GlassBorderBrush" Color="#38FFFFFF"/>
        <SolidColorBrush x:Key="GlassBorderStrongBrush" Color="#5EFFFFFF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B7D6E2EA"/>
        <SolidColorBrush x:Key="DimTextBrush" Color="#83D6E2EA"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#5AE8E0"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#5AA7FF"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#7BF5B5"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#FFD56A"/>
        <SolidColorBrush x:Key="RedBrush" Color="#FF6F86"/>

        <Style x:Key="GlassPanelStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource GlassPanelBrush}"/>
        </Style>

        <Style x:Key="GlassTileButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="158"/>
            <Setter Property="MinHeight" Value="92"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource GlassTileBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#34FFFFFF"/>
            <Setter Property="Background" Value="#2BFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PrimaryPillButtonStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
            <Setter Property="Background" Value="#D74F95FF"/>
            <Setter Property="BorderBrush" Value="#86D9F8FF"/>
        </Style>

        <Style x:Key="ZinkSubText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="TextWrapping" Value="WrapWholeWords"/>
            <Setter Property="MaxLines" Value="2"/>
        </Style>

        <Style x:Key="SignalCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="#51131D28"/>
            <Setter Property="BorderBrush" Value="#2CFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PulseButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="108"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2CFFFFFF"/>
            <Setter Property="Background" Value="#51131D28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
    </Page.Resources>

    <Grid RequestedTheme="Dark">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#060A10" Offset="0"/>
                <GradientStop Color="#0B1821" Offset="0.32"/>
                <GradientStop Color="#10261F" Offset="0.62"/>
                <GradientStop Color="#070A12" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Padding="32"
                  RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="18"
                                    Background="#224FE8E0"
                                    BorderBrush="#785AE8E0"
                                    BorderThickness="1">
                                <FontIcon Glyph="&#xE768;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="24"
                                          Foreground="{StaticResource CyanBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="0">
                                <TextBlock Text="Zink"
                                           FontSize="42"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="Play. Watch. Call. Share. Tune. Test."
                                           FontSize="15"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <AutoSuggestBox x:Name="HomeSearchBox"
                                        MaxWidth="760"
                                        MinHeight="46"
                                        PlaceholderText="Search Zink"
                                        QuerySubmitted="HomeSearchBox_QuerySubmitted"/>
                    </StackPanel>

                    <Button x:Name="NotificationsButton"
                            Grid.Column="1"
                            Width="54"
                            Height="54"
                            Padding="0"
                            CornerRadius="27"
                            BorderThickness="1"
                            BorderBrush="{StaticResource GlassBorderStrongBrush}"
                            Background="#30FFFFFF"
                            Foreground="White"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <Border Width="370"
                                        Padding="18"
                                        CornerRadius="26"
                                        BorderBrush="#44FFFFFF"
                                        BorderThickness="1"
                                        Background="{StaticResource GlassStrongBrush}">
                                    <StackPanel Spacing="14">
                                        <Grid>
                                            <TextBlock Text="Notifications"
                                                       FontSize="21"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock x:Name="NotificationsCountText"
                                                       Text="0"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource MutedTextBrush}"/>
                                        </Grid>
                                        <ItemsControl x:Name="NotificationsList"/>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                        <Grid Width="28" Height="28">
                            <FontIcon Glyph="&#xE7F4;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="19"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            <Border x:Name="NotificationsBadge"
                                    Width="10"
                                    Height="10"
                                    CornerRadius="10"
                                    Background="{StaticResource RedBrush}"
                                    BorderBrush="#CCFFFFFF"
                                    BorderThickness="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"/>
                        </Grid>
                    </Button>
                </Grid>

                <Grid x:Name="HeroInsightsSection"
                      Grid.Row="1"
                      ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.42*"/>
                        <ColumnDefinition Width="0.86*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource GlassPanelStyle}"
                            Padding="24"
                            Background="{StaticResource GlassStrongBrush}">
                        <Grid RowSpacing="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#D64F95FF" CornerRadius="999" Padding="12,5">
                                    <TextBlock x:Name="HeroKindText"
                                               Text="Idle"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#24232D38" CornerRadius="999" Padding="12,5" BorderBrush="#26FFFFFF" BorderThickness="1">
                                    <TextBlock x:Name="HeroMetaText"
                                               Text="Nothing active"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"/>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="1" ColumnSpacing="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="HeroTitle"
                                               Text="Your Zink session starts here"
                                               FontSize="46"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2"/>
                                    <TextBlock x:Name="HeroSubtitle"
                                               Text="Open your last media, keep Spotify visible, or jump into the spaces you use most."
                                               FontSize="16"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="3"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Width="220"
                                        Height="220"
                                        CornerRadius="30"
                                        BorderBrush="#405AE8E0"
                                        BorderThickness="1"
                                        Background="#80131D28">
                                    <Grid>
                                        <Image x:Name="HeroThumb"
                                               Stretch="UniformToFill"
                                               Visibility="Collapsed"/>
                                        <Grid x:Name="HeroThumbFallback">
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Spacing="12">
                                                <Grid Width="86" Height="86">
                                                    <Ellipse Fill="#263846"/>
                                                    <Ellipse Stroke="#805AE8E0" StrokeThickness="1"/>
                                                    <FontIcon Glyph="&#xE768;"
                                                              FontFamily="Segoe Fluent Icons"
                                                              FontSize="38"
                                                              Foreground="{StaticResource CyanBrush}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Grid>
                                                <TextBlock Text="Live"
                                                           Foreground="White"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="2" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource SignalCardStyle}">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Surface" Foreground="{StaticResource DimTextBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HeroTypeValue" Text="Nothing" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource SignalCardStyle}">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="State" Foreground="{StaticResource DimTextBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HeroPlaybackValue" Text="Stopped" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SignalCardStyle}">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Time" Foreground="{StaticResource DimTextBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HeroDurationValue" Text="-" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="3" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="ResumeButton"
                                            Style="{StaticResource PrimaryPillButtonStyle}"
                                            IsEnabled="False"
                                            Click="ResumeButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE768;" FontFamily="Segoe Fluent Icons" FontSize="15"/>
                                            <TextBlock Text="Resume"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource PillButtonStyle}" Click="OpenFileButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8E5;" FontFamily="Segoe Fluent Icons" FontSize="15"/>
                                            <TextBlock Text="Open file"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource PillButtonStyle}" Click="OpenFolderButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="15"/>
                                            <TextBlock Text="Open folder"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Border x:Name="HomeRadioVolumePanel"
                                        Grid.Row="1"
                                        Visibility="Collapsed"
                                        CornerRadius="22"
                                        Padding="14"
                                        Background="#4F131D28"
                                        BorderBrush="#28FFFFFF"
                                        BorderThickness="1">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Glyph="&#xE15D;"
                                                  FontFamily="Segoe Fluent Icons"
                                                  FontSize="18"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"/>

                                        <Slider x:Name="HomeRadioVolumeSlider"
                                                Grid.Column="1"
                                                Minimum="0"
                                                Maximum="100"
                                                StepFrequency="1"
                                                Value="50"
                                                VerticalAlignment="Center"
                                                ValueChanged="HomeRadioVolumeSlider_ValueChanged"/>

                                        <TextBlock x:Name="HomeRadioVolumeValueText"
                                                   Grid.Column="2"
                                                   Text="50%"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="14">
                        <Border Style="{StaticResource GlassPanelStyle}"
                                Padding="18"
                                Background="#80131D28">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Zink Pulse"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Style="{StaticResource PulseButtonStyle}" Click="PulseCalls_Click">
                                        <StackPanel Padding="15" Spacing="6">
                                            <FontIcon Glyph="&#xE717;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource BlueBrush}" FontSize="20"/>
                                            <TextBlock Text="Calls" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Voice and screen share" Style="{StaticResource ZinkSubText}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Style="{StaticResource PulseButtonStyle}" Click="PulseFps_Click">
                                        <StackPanel Padding="15" Spacing="6">
                                            <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource GreenBrush}" FontSize="20"/>
                                            <TextBlock Text="FPS" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Overlay and capture" Style="{StaticResource ZinkSubText}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Style="{StaticResource PulseButtonStyle}" Click="PulseStream_Click">
                                        <StackPanel Padding="15" Spacing="6">
                                            <FontIcon Glyph="&#xE8D4;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource CyanBrush}" FontSize="20"/>
                                            <TextBlock Text="Stream" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Quality and reports" Style="{StaticResource ZinkSubText}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Style="{StaticResource PulseButtonStyle}" Click="PulseLogs_Click">
                                        <StackPanel Padding="15" Spacing="6">
                                            <FontIcon Glyph="&#xE8A7;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource YellowBrush}" FontSize="20"/>
                                            <TextBlock Text="Logs" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Device diagnostics" Style="{StaticResource ZinkSubText}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid x:Name="RecentActivitySection" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <TextBlock Text="Recent"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource PillButtonStyle}"
                                        MinHeight="36"
                                        Padding="12,0"
                                        Click="ClearRecent_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="13"/>
                                        <TextBlock Text="Clear"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Grid.Row="1"
                                    Style="{StaticResource GlassPanelStyle}"
                                    Padding="8"
                                    MaxHeight="330"
                                    Background="#73131D28">
                                <ListView x:Name="RecentList"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsItemClickEnabled="True"
                                          ItemClick="RecentList_ItemClick"
                                          SelectionMode="Single">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="10" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="38" Height="38" CornerRadius="15" Background="#263846" BorderBrush="#24FFFFFF" BorderThickness="1">
                                                    <FontIcon Glyph="&#xE8D4;"
                                                              FontFamily="Segoe Fluent Icons"
                                                              Foreground="White"
                                                              FontSize="15"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding RightText}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="PowerToolsSection"
                            Grid.Row="2"
                            Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <Button x:Name="TileBtn_MusicPlayer" Style="{StaticResource GlassTileButtonStyle}" Click="MusicPlayer_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <FontIcon Glyph="&#xEC4F;" FontFamily="Segoe Fluent Icons" FontSize="26" Foreground="{StaticResource CyanBrush}"/>
                                <StackPanel Grid.Row="1" Spacing="3">
                                    <TextBlock Text="Music" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Player" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_VideoPlayer" Grid.Column="1" Style="{StaticResource GlassTileButtonStyle}" Click="VideoPlayer_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <FontIcon Glyph="&#xE714;" FontFamily="Segoe Fluent Icons" FontSize="26" Foreground="{StaticResource BlueBrush}"/>
                                <StackPanel Grid.Row="1" Spacing="3">
                                    <TextBlock Text="Video" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Player" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Radio" Grid.Column="2" Style="{StaticResource GlassTileButtonStyle}" Click="Radio_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <FontIcon Glyph="&#xE7F6;" FontFamily="Segoe Fluent Icons" FontSize="26" Foreground="{StaticResource YellowBrush}"/>
                                <StackPanel Grid.Row="1" Spacing="3">
                                    <TextBlock Text="Radio" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Live stations" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Spotify" Grid.Column="3" Style="{StaticResource GlassTileButtonStyle}" Click="Spotify_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <FontIcon Glyph="&#xE768;" FontFamily="Segoe Fluent Icons" FontSize="26" Foreground="{StaticResource GreenBrush}"/>
                                <StackPanel Grid.Row="1" Spacing="3">
                                    <TextBlock Text="Spotify" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Now playing" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <Button x:Name="TileBtn_MusicLibrary" Style="{StaticResource GlassTileButtonStyle}" Click="MusicLibrary_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe Fluent Icons" FontSize="26" Foreground="{StaticResource CyanBrush}"/>
                                <StackPanel Grid.Row="1" Spacing="3">
                                    <TextBlock Text="Music Library" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Files and albums" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_VideoLibrary" Grid.Column="1" Style="{StaticResource GlassTileButtonStyle}" Click="VideoLibrary_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <FontIcon Glyph="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="26" Foreground="{StaticResource BlueBrush}"/>
                                <StackPanel Grid.Row="1" Spacing="3">
                                    <TextBlock Text="Video Library" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Folders" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Equalizer" Grid.Column="2" Style="{StaticResource GlassTileButtonStyle}" Click="Equalizer_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <FontIcon Glyph="&#xE9E9;" FontFamily="Segoe Fluent Icons" FontSize="26" Foreground="{StaticResource YellowBrush}"/>
                                <StackPanel Grid.Row="1" Spacing="3">
                                    <TextBlock Text="Equalizer" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Audio tuning" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Visualizer" Grid.Column="3" Style="{StaticResource GlassTileButtonStyle}" Click="Visualizer_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <FontIcon Glyph="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="26" Foreground="{StaticResource GreenBrush}"/>
                                <StackPanel Grid.Row="1" Spacing="3">
                                    <TextBlock Text="Visualizer" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Reactive playback" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <Button x:Name="TileBtn_Twitch" Style="{StaticResource GlassTileButtonStyle}" Click="Twitch_Click">
                            <Grid Padding="16" RowSpacing="10">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
