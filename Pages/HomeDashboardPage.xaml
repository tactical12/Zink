<Page 
    x:Class="Zink.Pages.HomeDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Resources>

        <Style x:Key="ZinkCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        </Style>

        <Style x:Key="ZinkTileButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="ZinkSubText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="TextWrapping" Value="WrapWholeWords"/>
            <Setter Property="MaxLines" Value="2"/>
        </Style>

    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="32" RowSpacing="18">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Text="Zink" FontSize="34" FontWeight="Bold"/>
                <TextBlock Text="Your media hub - everything connected."
                           Opacity="0.75"
                           FontSize="14"/>

                <Border Margin="0,10,0,0"
                        CornerRadius="14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <AutoSuggestBox x:Name="HomeSearchBox"
                                    Margin="10,8"
                                    PlaceholderText="Search songs, albums, artists, videos, stations"
                                    QuerySubmitted="HomeSearchBox_QuerySubmitted"/>
                </Border>
            </StackPanel>

            <Grid x:Name="HeroInsightsSection" Grid.Row="1" Margin="0,6,0,0">
                <Border Style="{StaticResource ZinkCardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border CornerRadius="16,16,0,0"
                                Height="76"
                                Background="{ThemeResource AccentFillColorSecondaryBrush}">
                            <Grid Padding="22,0,22,0">
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Now Playing"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Live playback hub for music, radio, and video"
                                               FontSize="13"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Padding="22" ColumnSpacing="22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="210"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="18"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    Width="210"
                                    Height="210">
                                <Grid>
                                    <Image x:Name="HeroThumb"
                                           Stretch="UniformToFill"
                                           Visibility="Collapsed"/>

                                    <Grid x:Name="HeroThumbFallback"
                                          Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Spacing="10">
                                            <FontIcon Glyph="&#xE189;"
                                                      FontSize="42"
                                                      HorizontalAlignment="Center"
                                                      Opacity="0.82"/>
                                            <TextBlock Text="Now Playing"
                                                       HorizontalAlignment="Center"
                                                       FontSize="14"
                                                       Opacity="0.82"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="1" RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="999"
                                            Padding="10,4">
                                        <TextBlock x:Name="HeroKindText"
                                                   Text="Idle"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Border>

                                    <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="999"
                                            Padding="10,4">
                                        <TextBlock x:Name="HeroMetaText"
                                                   Text="Nothing active"
                                                   FontSize="12"
                                                   Opacity="0.82"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Spacing="4">
                                    <TextBlock x:Name="HeroTitle"
                                               Text="Nothing playing yet"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2"/>
                                    <TextBlock x:Name="HeroSubtitle"
                                               Text="Play music, radio or a film and it will appear here"
                                               FontSize="14"
                                               Opacity="0.76"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="3"/>
                                </StackPanel>

                                <Rectangle Grid.Row="2"
                                           Height="1"
                                           Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                           Opacity="0.85"/>

                                <Grid Grid.Row="3" ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Type"
                                                   FontSize="12"
                                                   Opacity="0.65"/>
                                        <TextBlock x:Name="HeroTypeValue"
                                                   Text="Nothing"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Playback"
                                                   FontSize="12"
                                                   Opacity="0.65"/>
                                        <TextBlock x:Name="HeroPlaybackValue"
                                                   Text="Stopped"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="2">
                                        <TextBlock Text="Duration"
                                                   FontSize="12"
                                                   Opacity="0.65"/>
                                        <TextBlock x:Name="HeroDurationValue"
                                                   Text="-"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="ResumeButton"
                                            Content="Resume"
                                            IsEnabled="False"
                                            Click="ResumeButton_Click"/>
                                    <Button Content="Open file"
                                            Click="OpenFileButton_Click"/>
                                    <Button Content="Open folder"
                                            Click="OpenFolderButton_Click"/>
                                </StackPanel>

                                <Border Grid.Row="5"
                                        CornerRadius="14"
                                        Padding="14"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Live media area"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Shows the latest live song, radio station, or video in Zink."
                                                   FontSize="13"
                                                   Opacity="0.75"
                                                   TextWrapping="WrapWholeWords"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Visibility="Collapsed">
                                    <TextBlock x:Name="TimeWatchedText" Text="0m"/>
                                    <TextBlock x:Name="TimeListenedText" Text="0m"/>
                                    <TextBlock x:Name="MostUsedText" Text="-"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel x:Name="PowerToolsSection" Grid.Row="2" Spacing="10" Margin="0,6,0,0">
                <TextBlock Text="Power tools" FontSize="18" FontWeight="SemiBold"/>

                <Border Style="{StaticResource ZinkCardStyle}" Padding="14">

                    <ItemsControl HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                               MaximumRowsOrColumns="4"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               ItemHeight="94"
                                               ItemWidth="300"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.Items>

                            <Button x:Name="TileBtn_MusicPlayer" Style="{StaticResource ZinkTileButtonStyle}" Click="MusicPlayer_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE189;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Music Player" FontWeight="SemiBold"/>
                                        <TextBlock Text="Queue, playback, controls" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_VideoPlayer" Style="{StaticResource ZinkTileButtonStyle}" Click="VideoPlayer_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE714;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Video Player" FontWeight="SemiBold"/>
                                        <TextBlock Text="Subtitles, progress, fullscreen" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Radio" Style="{StaticResource ZinkTileButtonStyle}" Click="Radio_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE12B;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Radio" FontWeight="SemiBold"/>
                                        <TextBlock Text="Stations, likes, history" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_VideoLibrary" Style="{StaticResource ZinkTileButtonStyle}" Click="VideoLibrary_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE8B2;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Video Library" FontWeight="SemiBold"/>
                                        <TextBlock Text="Browse and manage videos" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_MusicLibrary" Style="{StaticResource ZinkTileButtonStyle}" Click="MusicLibrary_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE8D6;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Music Library" FontWeight="SemiBold"/>
                                        <TextBlock Text="Browse and manage music" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Equalizer" Style="{StaticResource ZinkTileButtonStyle}" Click="Equalizer_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE9E9;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Equalizer" FontWeight="SemiBold"/>
                                        <TextBlock Text="Tune your sound" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Visualizer" Style="{StaticResource ZinkTileButtonStyle}" Click="Visualizer_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xEC4A;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Visualizer" FontWeight="SemiBold"/>
                                        <TextBlock Text="Live effects while playing" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Settings" Style="{StaticResource ZinkTileButtonStyle}" Click="Settings_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE713;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Settings" FontWeight="SemiBold"/>
                                        <TextBlock Text="App, playback, hub options" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_VersionHistory" Style="{StaticResource ZinkTileButtonStyle}" Click="VersionHistory_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE823;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Version history" FontWeight="SemiBold"/>
                                        <TextBlock Text="What's new and changes" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Spotify" Style="{StaticResource ZinkTileButtonStyle}" Click="Spotify_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE8D6;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Spotify" FontWeight="SemiBold"/>
                                        <TextBlock Text="Music, playlists, discovery" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Twitch" Style="{StaticResource ZinkTileButtonStyle}" Click="Twitch_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE714;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Twitch" FontWeight="SemiBold"/>
                                        <TextBlock Text="Live streams and creators" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Xbox" Style="{StaticResource ZinkTileButtonStyle}" Click="Xbox_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE7FC;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Xbox" FontWeight="SemiBold"/>
                                        <TextBlock Text="Profile, achievements, games" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Discord" Style="{StaticResource ZinkTileButtonStyle}" Click="Discord_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE8BD;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Discord" FontWeight="SemiBold"/>
                                        <TextBlock Text="Calls, chat, community" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_YouTube" Style="{StaticResource ZinkTileButtonStyle}" Click="YouTube_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE714;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="YouTube" FontWeight="SemiBold"/>
                                        <TextBlock Text="Videos, music, creators" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="TileBtn_Customise" Style="{StaticResource ZinkTileButtonStyle}" Click="Customise_Click">
                                <Grid Padding="14" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE771;" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Customise" FontWeight="SemiBold"/>
                                        <TextBlock Text="Personalise dashboard and layout" Style="{StaticResource ZinkSubText}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                        </ItemsControl.Items>
                    </ItemsControl>

                </Border>
            </StackPanel>

            <Grid x:Name="RecentActivitySection" Grid.Row="3" RowSpacing="10" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Recent activity"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Button Grid.Column="1"
                            Content="Clear"
                            HorizontalAlignment="Right"
                            Click="ClearRecent_Click"/>
                </Grid>

                <Border Grid.Row="1"
                        Style="{StaticResource ZinkCardStyle}"
                        Padding="8">

                    <ListView x:Name="RecentList"
                              Background="Transparent"
                              BorderThickness="0"
                              IsItemClickEnabled="True"
                              ItemClick="RecentList_ItemClick"
                              SelectionMode="Single">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Glyph="&#xE8D4;" Opacity="0.8" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Spacing="1">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding RightText}"
                                               Opacity="0.6"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>
                </Border>
            </Grid>

        </Grid>
    </ScrollViewer>
</Page>