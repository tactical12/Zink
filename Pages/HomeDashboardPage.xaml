<Page
    x:Class="Zink.Pages.HomeDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="GlassPanelBrush" Color="#B0141820"/>
        <SolidColorBrush x:Key="GlassPanelStrongBrush" Color="#C2182530"/>
        <SolidColorBrush x:Key="GlassTileBrush" Color="#8F101820"/>
        <SolidColorBrush x:Key="GlassPanelBorderBrush" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B7C8D2DC"/>
        <SolidColorBrush x:Key="ZinkAccentBrush" Color="#50E6D7"/>
        <SolidColorBrush x:Key="ZinkBlueBrush" Color="#2E8DFF"/>
        <SolidColorBrush x:Key="ZinkGreenBrush" Color="#63F4A8"/>

        <Style x:Key="GlassPanelStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassPanelBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource GlassPanelBrush}"/>
        </Style>

        <Style x:Key="GlassTileButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="88"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource GlassTileBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="CornerRadius" Value="21"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="Background" Value="#2DFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PrimaryPillButtonStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
            <Setter Property="Background" Value="#D72E8DFF"/>
            <Setter Property="BorderBrush" Value="#80D8F0FF"/>
        </Style>

        <Style x:Key="ZinkSubText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="TextWrapping" Value="WrapWholeWords"/>
            <Setter Property="MaxLines" Value="2"/>
        </Style>
    </Page.Resources>

    <Grid RequestedTheme="Dark">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#081017" Offset="0"/>
                <GradientStop Color="#102333" Offset="0.42"/>
                <GradientStop Color="#071513" Offset="0.72"/>
                <GradientStop Color="#04070B" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Padding="30"
                  RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource GlassPanelStyle}"
                        Padding="18">
                    <Grid ColumnSpacing="18"
                          RowSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="3">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10">
                                <Border Width="34"
                                        Height="34"
                                        CornerRadius="10"
                                        Background="#334EF0E5"
                                        BorderBrush="#6650E6D7"
                                        BorderThickness="1">
                                    <FontIcon Glyph="&#xE8D4;"
                                              FontSize="16"
                                              Foreground="{StaticResource ZinkAccentBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Zink"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Your media, calls, screen share, gaming tools and diagnostics in one place."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="WrapWholeWords"/>
                        </StackPanel>

                        <AutoSuggestBox x:Name="HomeSearchBox"
                                        Grid.Row="1"
                                        MinHeight="46"
                                        PlaceholderText="Search Zink: songs, videos, stations, web pages and tools"
                                        QuerySubmitted="HomeSearchBox_QuerySubmitted"/>

                        <Button x:Name="NotificationsButton"
                                Grid.Column="1"
                                Grid.RowSpan="2"
                                MinWidth="54"
                                MinHeight="46"
                                Padding="14,0"
                                CornerRadius="23"
                                BorderThickness="1"
                                BorderBrush="#55FFFFFF"
                                Background="#33FFFFFF"
                                Foreground="White"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <Border Width="360"
                                            Padding="18"
                                            CornerRadius="24"
                                            BorderBrush="#44FFFFFF"
                                            BorderThickness="1"
                                            Background="{StaticResource GlassPanelStrongBrush}">
                                        <StackPanel Spacing="14">
                                            <Grid>
                                                <TextBlock Text="Notifications"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock x:Name="NotificationsCountText"
                                                           Text="0"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource MutedTextBrush}"/>
                                            </Grid>
                                            <ItemsControl x:Name="NotificationsList"/>
                                        </StackPanel>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                            <Grid Width="26"
                                  Height="26">
                                <FontIcon Glyph="&#xE7F4;"
                                          FontSize="18"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                <Border x:Name="NotificationsBadge"
                                        Width="9"
                                        Height="9"
                                        CornerRadius="9"
                                        Background="#FF4D5C"
                                        BorderBrush="#CCFFFFFF"
                                        BorderThickness="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <Grid x:Name="HeroInsightsSection"
                      Grid.Row="1">
                    <Border Style="{StaticResource GlassPanelStyle}"
                            Padding="22"
                            Background="{StaticResource GlassPanelStrongBrush}">
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border CornerRadius="24"
                                    BorderThickness="1"
                                    BorderBrush="#4050E6D7"
                                    Background="#97101820"
                                    Width="280"
                                    Height="280">
                                <Grid>
                                    <Image x:Name="HeroThumb"
                                           Stretch="UniformToFill"
                                           Visibility="Collapsed"/>

                                    <Grid x:Name="HeroThumbFallback">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Spacing="12">
                                            <Grid Width="78" Height="78">
                                                <Ellipse Fill="#273B45"/>
                                                <Ellipse Stroke="#8050E6D7"
                                                         StrokeThickness="1"/>
                                                <FontIcon Glyph="&#xE189;"
                                                          FontSize="34"
                                                          Foreground="{StaticResource ZinkAccentBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="Zink live surface"
                                                       Foreground="White"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                                <Grid Grid.Column="1"
                                      RowSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Border Background="#D72E8DFF"
                                            CornerRadius="999"
                                            Padding="12,5">
                                        <TextBlock x:Name="HeroKindText"
                                                   Text="Idle"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Border>

                                    <Border Background="#2BFFFFFF"
                                            CornerRadius="999"
                                            Padding="12,5"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <TextBlock x:Name="HeroMetaText"
                                                   Text="Nothing active"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"/>
                                    </Border>

                                    <Border Background="#2434E6A7"
                                            CornerRadius="999"
                                            Padding="12,5"
                                            BorderBrush="#4450E6D7"
                                            BorderThickness="1">
                                        <TextBlock Text="Media + Calls + Gaming"
                                                   Foreground="#D7FFF9"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="1"
                                            Spacing="6">
                                    <TextBlock x:Name="HeroTitle"
                                               Text="Your Zink session starts here"
                                               FontSize="38"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2"/>
                                    <TextBlock x:Name="HeroSubtitle"
                                               Text="Play music, watch video, stream your screen, join calls, and keep diagnostics ready when something needs fixing."
                                               FontSize="15"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="3"/>
                                </StackPanel>

                                <Grid Grid.Row="2"
                                      ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="14"
                                            CornerRadius="16"
                                            Background="{StaticResource GlassTileBrush}"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Surface"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                            <TextBlock x:Name="HeroTypeValue"
                                                       Text="Nothing"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Padding="14"
                                            CornerRadius="16"
                                            Background="{StaticResource GlassTileBrush}"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="State"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                            <TextBlock x:Name="HeroPlaybackValue"
                                                       Text="Stopped"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="14"
                                            CornerRadius="16"
                                            Background="{StaticResource GlassTileBrush}"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Session"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                            <TextBlock x:Name="HeroDurationValue"
                                                       Text="-"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="3"
                                            Orientation="Horizontal"
                                            Spacing="10">
                                    <Button x:Name="ResumeButton"
                                            Style="{StaticResource PrimaryPillButtonStyle}"
                                            IsEnabled="False"
                                            Click="ResumeButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE768;" FontSize="15"/>
                                            <TextBlock Text="Resume"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource PillButtonStyle}"
                                            Click="OpenFileButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8E5;" FontSize="15"/>
                                            <TextBlock Text="Open file"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource PillButtonStyle}"
                                            Click="OpenFolderButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="15"/>
                                            <TextBlock Text="Open folder"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Border x:Name="HomeRadioVolumePanel"
                                        Grid.Row="4"
                                        Visibility="Collapsed"
                                        CornerRadius="20"
                                        Padding="14"
                                        Background="{StaticResource GlassTileBrush}"
                                        BorderBrush="#24FFFFFF"
                                        BorderThickness="1">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Glyph="&#xE15D;"
                                                  FontSize="18"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"/>

                                        <Slider x:Name="HomeRadioVolumeSlider"
                                                Grid.Column="1"
                                                Minimum="0"
                                                Maximum="100"
                                                StepFrequency="1"
                                                Value="50"
                                                VerticalAlignment="Center"
                                                ValueChanged="HomeRadioVolumeSlider_ValueChanged"/>

                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Spacing="2">
                                            <TextBlock Text="Volume"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock x:Name="HomeRadioVolumeValueText"
                                                       Text="50%"
                                                       Foreground="White"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel x:Name="PowerToolsSection"
                            Grid.Row="2"
                            Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Zink spaces"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Jump into the parts of Zink you actually use: listening, watching, sharing, calling, gaming and tuning."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>

                    <Grid ColumnSpacing="12"
                          RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button x:Name="TileBtn_MusicPlayer" Style="{StaticResource GlassTileButtonStyle}" Click="MusicPlayer_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/music-player.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Music Player" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Local music queue and playback" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_VideoPlayer" Grid.Column="1" Style="{StaticResource GlassTileButtonStyle}" Click="VideoPlayer_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/video-player.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Video Player" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Films, clips, subtitles, fullscreen" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Radio" Grid.Column="2" Style="{StaticResource GlassTileButtonStyle}" Click="Radio_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/radio.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Radio" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Live stations and liked radio songs" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_VideoLibrary" Grid.Column="3" Style="{StaticResource GlassTileButtonStyle}" Click="VideoLibrary_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/video-library.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Video Library" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Your video collection and folders" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_MusicLibrary" Grid.Row="1" Style="{StaticResource GlassTileButtonStyle}" Click="MusicLibrary_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/music-library.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Music Library" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Songs, folders, albums and files" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Equalizer" Grid.Row="1" Grid.Column="1" Style="{StaticResource GlassTileButtonStyle}" Click="Equalizer_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/equalizer.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Equalizer" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Shape playback for music and films" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Visualizer" Grid.Row="1" Grid.Column="2" Style="{StaticResource GlassTileButtonStyle}" Click="Visualizer_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/visualizer.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Visualizer" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Reactive visuals for playback" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Settings" Grid.Row="1" Grid.Column="3" Style="{StaticResource GlassTileButtonStyle}" Click="Settings_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/settings.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Settings" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Diagnostics, startup and app options" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_VersionHistory" Grid.Row="2" Style="{StaticResource GlassTileButtonStyle}" Click="VersionHistory_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/version-history.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Version history" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Updates, fixes and release notes" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Spotify" Grid.Row="2" Grid.Column="1" Style="{StaticResource GlassTileButtonStyle}" Click="Spotify_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/spotify.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Spotify" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Desktop now playing and playlists" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Twitch" Grid.Row="2" Grid.Column="2" Style="{StaticResource GlassTileButtonStyle}" Click="Twitch_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/twitch.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Twitch" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Streams and creator pages" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Xbox" Grid.Row="2" Grid.Column="3" Style="{StaticResource GlassTileButtonStyle}" Click="Xbox_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/xbox.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Xbox" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Gaming profile and tools" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Discord" Grid.Row="3" Style="{StaticResource GlassTileButtonStyle}" Click="Discord_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/discord.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Discord" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Presence, calls and community" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_YouTube" Grid.Row="3" Grid.Column="1" Style="{StaticResource GlassTileButtonStyle}" Click="YouTube_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/youtube.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="YouTube" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Watch videos and music pages" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="TileBtn_Customise" Grid.Row="3" Grid.Column="2" Style="{StaticResource GlassTileButtonStyle}" Click="Customise_Click">
                            <Grid Padding="16" ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1">
                                    <Image Source="ms-appx:///Assets/QuickAccess/customise.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock Text="Customise" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Glass style, layout and dashboard" Style="{StaticResource ZinkSubText}"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </Grid>
                </StackPanel>

                <Grid x:Name="RecentActivitySection"
                      Grid.Row="3"
                      Height="0"
                      Visibility="Collapsed"
                      RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Recent activity"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource PillButtonStyle}"
                                HorizontalAlignment="Right"
                                Click="ClearRecent_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                <TextBlock Text="Clear"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1"
                            Style="{StaticResource GlassPanelStyle}"
                            Padding="10">
                        <ListView x:Name="RecentList"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  IsItemClickEnabled="True"
                                  ItemClick="RecentList_ItemClick"
                                  SelectionMode="Single">

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="10"
                                          ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="38" Height="38">
                                            <Ellipse Fill="#263847"/>
                                            <FontIcon Glyph="&#xE8D4;"
                                                      Foreground="White"
                                                      FontSize="15"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitle}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding RightText}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
