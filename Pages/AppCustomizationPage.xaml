<Page
    x:Class="Zink.Pages.AppCustomizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B8C8D2DC"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#071019" Offset="0"/>
                <GradientStop Color="#142B37" Offset="0.48"/>
                <GradientStop Color="#07090D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Padding="32" RowSpacing="22" MaxWidth="1060">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock Text="App customisation"
                               FontSize="38"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Tune the look and dashboard layout without digging through settings."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="15"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Row="1" ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Click="AppTheme_Click"
                            Padding="0"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0">
                        <Border Padding="24"
                                CornerRadius="30"
                                Background="{StaticResource ZinkGlassPanelBrush}"
                                BorderBrush="{StaticResource ZinkGlassBorderBrush}"
                                BorderThickness="1">
                            <Grid RowSpacing="18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="60"
                                            Height="60"
                                            CornerRadius="20"
                                            Background="#2DFFFFFF"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <FontIcon Glyph="&#xE771;"
                                                  FontSize="26"
                                                  Foreground="#8CEBFF"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>

                                    <FontIcon Grid.Column="2"
                                              Glyph="&#xE72A;"
                                              Foreground="{StaticResource MutedTextBrush}"
                                              VerticalAlignment="Center"/>
                                </Grid>

                                <StackPanel Grid.Row="1" Spacing="6">
                                    <TextBlock Text="App theme and glass"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <TextBlock Text="Choose Light, Dark, or follow Windows, then tint the fluent glass UI."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid Grid.Row="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Height="44" CornerRadius="14" Background="#F1F5F8"/>
                                    <Border Grid.Column="1" Height="44" CornerRadius="14" Background="#1A222B"/>
                                    <Border Grid.Column="2" Height="44" CornerRadius="14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#F1F5F8" Offset="0"/>
                                                <GradientStop Color="#F1F5F8" Offset="0.5"/>
                                                <GradientStop Color="#1A222B" Offset="0.5"/>
                                                <GradientStop Color="#1A222B" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Button>

                    <Button Grid.Column="1"
                            Click="DashboardCustomise_Click"
                            Padding="0"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0">
                        <Border Padding="24"
                                CornerRadius="30"
                                Background="{StaticResource ZinkGlassPanelBrush}"
                                BorderBrush="{StaticResource ZinkGlassBorderBrush}"
                                BorderThickness="1">
                            <Grid RowSpacing="18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="60"
                                            Height="60"
                                            CornerRadius="20"
                                            Background="#2DFFFFFF"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <FontIcon Glyph="&#xE80F;"
                                                  FontSize="26"
                                                  Foreground="#A7FFC8"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>

                                    <FontIcon Grid.Column="2"
                                              Glyph="&#xE72A;"
                                              Foreground="{StaticResource MutedTextBrush}"
                                              VerticalAlignment="Center"/>
                                </Grid>

                                <StackPanel Grid.Row="1" Spacing="6">
                                    <TextBlock Text="Home dashboard"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <TextBlock Text="Toggle the sections and tiles shown on Home."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid Grid.Row="2" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Height="12" CornerRadius="6" Background="#30FFFFFF"/>
                                    <Border Grid.Row="1" Height="12" CornerRadius="6" Background="#24FFFFFF" Margin="0,0,68,0"/>
                                    <Border Grid.Row="2" Height="12" CornerRadius="6" Background="#18FFFFFF" Margin="0,0,120,0"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Button>
                </Grid>

                <Border Grid.Row="2"
                        Padding="22"
                        CornerRadius="26"
                        Background="{StaticResource ZinkGlassCardBrush}"
                        BorderBrush="#26FFFFFF"
                        BorderThickness="1">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="46"
                                Height="46"
                                CornerRadius="16"
                                Background="#25FFFFFF">
                            <FontIcon Glyph="&#xE946;"
                                      Foreground="#D6F6FF"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Theme and glass colour changes apply immediately."
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Theme controls the overall app appearance. Glass colour controls the fluent shell tint, selected states, and theme preview."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
