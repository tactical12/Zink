<Page
    x:Class="Zink.Pages.AppCustomizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="App customisation"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock Text="Personalise how Zink looks and behaves."
                       Opacity="0.75"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Tiles -->
        <StackPanel Grid.Row="1" Spacing="12" Margin="0,16,0,0">

            <!-- App Theme Tile -->
            <Button Click="AppTheme_Click"
                    HorizontalAlignment="Stretch"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid Padding="16" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}">
                        <Viewbox>
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE771;" />
                        </Viewbox>
                    </Border>

                    <!-- Text -->
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="App theme"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Choose Light, Dark, or follow the system setting."
                                   Opacity="0.75"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Chevron -->
                    <FontIcon Grid.Column="2"
                              FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE72A;"
                              Opacity="0.75"
                              VerticalAlignment="Center"/>
                </Grid>
            </Button>

            <!-- Home Dashboard Customisation Tile -->
            <Button Click="DashboardCustomise_Click"
                    HorizontalAlignment="Stretch"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid Padding="16" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}">
                        <Viewbox>
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE80F;" />
                        </Viewbox>
                    </Border>

                    <!-- Text -->
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Home dashboard customisation"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Toggle sections and tiles shown on your Home page."
                                   Opacity="0.75"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Chevron -->
                    <FontIcon Grid.Column="2"
                              FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE72A;"
                              Opacity="0.75"
                              VerticalAlignment="Center"/>
                </Grid>
            </Button>

        </StackPanel>

        <!-- Tip (kept, but visually calmer) -->
        <TextBlock Grid.Row="2"
                   Margin="0,16,0,0"
                   Text="Tip: App theme controls the overall Light/Dark/System look. Dashboard customisation lets you toggle sections and tiles on the Home page."
                   Opacity="0.60"
                   TextWrapping="Wrap"/>
    </Grid>
</Page>
