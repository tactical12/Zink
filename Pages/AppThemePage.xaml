<Page
    x:Class="Zink.Pages.AppThemePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="App theme" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Choose how Zink looks. You can follow Windows, or force Light/Dark."
                       Opacity="0.75"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Current -->
        <TextBlock x:Name="CurrentThemeText"
                   Grid.Row="1"
                   Opacity="0.75"
                   Text="Current: Use system setting"/>

        <!-- Theme tiles -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">

            <!-- System -->
            <Button x:Name="SystemThemeButton"
                    Click="SystemThemeButton_Click"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Width="180">
                    <Grid Height="92">
                        <Rectangle Fill="#F3F3F3"/>
                        <Rectangle Fill="#1E1E1E" HorizontalAlignment="Right" Width="90"/>
                    </Grid>

                    <StackPanel Padding="12" Spacing="2">
                        <TextBlock Text="Use system" FontWeight="SemiBold"/>
                        <TextBlock Text="Match Windows theme" Opacity="0.70"/>
                    </StackPanel>
                </StackPanel>
            </Button>

            <!-- Light -->
            <Button x:Name="LightThemeButton"
                    Click="LightThemeButton_Click"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Width="180">
                    <Border Height="92" Background="#F3F3F3"/>
                    <StackPanel Padding="12" Spacing="2">
                        <TextBlock Text="Light" FontWeight="SemiBold"/>
                        <TextBlock Text="Bright appearance" Opacity="0.70"/>
                    </StackPanel>
                </StackPanel>
            </Button>

            <!-- Dark -->
            <Button x:Name="DarkThemeButton"
                    Click="DarkThemeButton_Click"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Width="180">
                    <Border Height="92" Background="#1E1E1E"/>
                    <StackPanel Padding="12" Spacing="2">
                        <TextBlock Text="Dark" FontWeight="SemiBold"/>
                        <TextBlock Text="Dim appearance" Opacity="0.70"/>
                    </StackPanel>
                </StackPanel>
            </Button>

        </StackPanel>

        <!-- Preview -->
        <Border Grid.Row="3"
                Margin="0,6,0,0"
                Padding="16"
                CornerRadius="16"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="12">

                <StackPanel>
                    <TextBlock Text="Preview" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="This is a small preview of how the app will look."
                               Opacity="0.70"/>
                </StackPanel>

                <!-- Fake mini UI preview -->
                <Border CornerRadius="12"
                        Padding="12"
                        Background="{ThemeResource ControlAltFillColorSecondaryBrush}">
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="34" Height="34" CornerRadius="10"
                                    Background="{ThemeResource ControlAltFillColorTertiaryBrush}"/>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="2">
                                <TextBlock Text="Zink" FontWeight="SemiBold"/>
                                <TextBlock Text="Home dashboard" Opacity="0.70" FontSize="12"/>
                            </StackPanel>

                            <Border Grid.Column="2" Width="54" Height="24" CornerRadius="8"
                                    Background="{ThemeResource ControlAltFillColorTertiaryBrush}"/>
                        </Grid>

                        <Border Height="12" CornerRadius="6"
                                Background="{ThemeResource ControlAltFillColorTertiaryBrush}"/>

                        <Border Height="12" CornerRadius="6"
                                Background="{ThemeResource ControlAltFillColorTertiaryBrush}"/>

                        <Border Height="12" CornerRadius="6"
                                Background="{ThemeResource ControlAltFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</Page>
