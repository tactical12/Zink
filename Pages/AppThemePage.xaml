<Page
    x:Class="Zink.Pages.AppThemePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="ThemePanelBrush" Color="#B0141820"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#82121C26"/>
        <SolidColorBrush x:Key="ThemeBorderBrush" Color="#34FFFFFF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B8C8D2DC"/>
        <SolidColorBrush x:Key="SelectedStrokeBrush" Color="#8CEBFF"/>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="PageGradientStart" Color="#002333" Offset="0"/>
                <GradientStop x:Name="PageGradientMiddle" Color="#00394B" Offset="0.48"/>
                <GradientStop Color="#061019" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Padding="32" RowSpacing="22" MaxWidth="1120">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Click="BackButton_Click"
                            Width="46"
                            Height="46"
                            CornerRadius="16"
                            Background="{StaticResource ThemeCardBrush}"
                            BorderBrush="{StaticResource ThemeBorderBrush}"
                            VerticalAlignment="Top">
                        <FontIcon Glyph="&#xE72B;"
                                  FontFamily="Segoe Fluent Icons"
                                  Foreground="White"/>
                    </Button>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="App theme"
                                   FontSize="38"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Choose the app theme and tint the fluent glass UI across Zink."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <Border Padding="22"
                            CornerRadius="28"
                            Background="{StaticResource ThemePanelBrush}"
                            BorderBrush="{StaticResource ThemeBorderBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="5">
                                <TextBlock Text="Mode"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock x:Name="CurrentThemeText"
                                           Text="Current: Use system setting"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>

                            <Grid Grid.Row="1" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="SystemThemeButton"
                                        Click="SystemThemeButton_Click"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource ThemeBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <Grid Height="104">
                                            <Rectangle Fill="#F3F6FA"/>
                                            <Rectangle Fill="#151D26" HorizontalAlignment="Right" Width="92"/>
                                        </Grid>
                                        <StackPanel Padding="14" Spacing="3">
                                            <TextBlock Text="System" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Match Windows" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="LightThemeButton"
                                        Grid.Column="1"
                                        Click="LightThemeButton_Click"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource ThemeBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <Border Height="104" Background="#F3F6FA"/>
                                        <StackPanel Padding="14" Spacing="3">
                                            <TextBlock Text="Light" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Bright surfaces" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="DarkThemeButton"
                                        Grid.Column="2"
                                        Click="DarkThemeButton_Click"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource ThemeBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <Border Height="104" Background="#151D26"/>
                                        <StackPanel Padding="14" Spacing="3">
                                            <TextBlock Text="Dark" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Dim surfaces" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Grid.Row="2"
                                    Padding="16"
                                    CornerRadius="18"
                                    Background="{StaticResource ThemeCardBrush}"
                                    BorderBrush="#26FFFFFF"
                                    BorderThickness="1">
                                <StackPanel Spacing="11">
                                    <TextBlock Text="Glass colour"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                    <Grid ColumnSpacing="10" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="46"/>
                                            <RowDefinition Height="46"/>
                                        </Grid.RowDefinitions>
                                        <Button Tag="#3F6F7F" Click="PresetColor_Click" Background="#3F6F7F" BorderBrush="#55FFFFFF"/>
                                        <Button Grid.Column="1" Tag="#1B4D5C" Click="PresetColor_Click" Background="#1B4D5C" BorderBrush="#55FFFFFF"/>
                                        <Button Grid.Column="2" Tag="#183B64" Click="PresetColor_Click" Background="#183B64" BorderBrush="#55FFFFFF"/>
                                        <Button Grid.Column="3" Tag="#43295A" Click="PresetColor_Click" Background="#43295A" BorderBrush="#55FFFFFF"/>
                                        <Button Grid.Row="1" Tag="#184D3A" Click="PresetColor_Click" Background="#184D3A" BorderBrush="#55FFFFFF"/>
                                        <Button Grid.Row="1" Grid.Column="1" Tag="#5C2D2D" Click="PresetColor_Click" Background="#5C2D2D" BorderBrush="#55FFFFFF"/>
                                        <Button Grid.Row="1" Grid.Column="2" Tag="#5A4B22" Click="PresetColor_Click" Background="#5A4B22" BorderBrush="#55FFFFFF"/>
                                        <Button Grid.Row="1" Grid.Column="3" Tag="#252A35" Click="PresetColor_Click" Background="#252A35" BorderBrush="#55FFFFFF"/>
                                    </Grid>
                                    <TextBlock x:Name="CurrentGlassText"
                                               Text="Glass colour: #3F6F7F"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="22"
                            CornerRadius="28"
                            Background="{StaticResource ThemePanelBrush}"
                            BorderBrush="{StaticResource ThemeBorderBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Custom tint"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="Pick any colour for the shell glass, selected states, and preview."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <ColorPicker x:Name="GlassColorPicker"
                                         ColorChanged="GlassColorPicker_ColorChanged"
                                         IsAlphaEnabled="False"
                                         IsAlphaSliderVisible="False"
                                         IsAlphaTextInputVisible="False"
                                         IsMoreButtonVisible="False"
                                         IsColorSliderVisible="True"
                                         IsColorChannelTextInputVisible="True"
                                         IsHexInputVisible="True"/>

                            <Button Content="Reset all colour to the default"
                                    Click="ResetGlassColor_Click"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="44"
                                    CornerRadius="16"
                                    Background="{StaticResource ThemeCardBrush}"
                                    BorderBrush="{StaticResource ThemeBorderBrush}"
                                    Foreground="White"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Padding="22"
                        CornerRadius="28"
                        Background="{StaticResource ThemeCardBrush}"
                        BorderBrush="#26FFFFFF"
                        BorderThickness="1">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border CornerRadius="24"
                                Padding="16"
                                Background="{StaticResource ZinkGlassPanelBrush}"
                                BorderBrush="{StaticResource ZinkGlassBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="42"
                                            Height="42"
                                            CornerRadius="14"
                                            Background="#2DFFFFFF"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <FontIcon Glyph="&#xE771;"
                                                  Foreground="#D6F6FF"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Zink" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="Fluent glass" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Width="52"
                                            Height="28"
                                            CornerRadius="10"
                                            Background="{StaticResource ZinkGlassSelectedBrush}"/>
                                </Grid>
                                <Border Height="13" CornerRadius="7" Background="#32FFFFFF"/>
                                <Border Height="13" CornerRadius="7" Background="#24FFFFFF" Margin="0,0,52,0"/>
                                <Border Height="13" CornerRadius="7" Background="#18FFFFFF" Margin="0,0,104,0"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Spacing="5"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Live preview"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="18"/>
                            <TextBlock Text="The selected tint is saved and applied immediately to the main fluent glass shell."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
