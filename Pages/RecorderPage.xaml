<Page
    x:Class="Zink.Pages.RecorderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Zink.Models"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">

            <TextBlock Text="Screen Recorder"
                       FontSize="28"
                       FontWeight="SemiBold"/>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Status" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusText" Text="Idle"/>
                    <TextBlock x:Name="TargetText" Text="No capture target selected."/>
                    <TextBlock x:Name="ManualStateText" Text="Manual recording: Stopped"/>
                    <TextBlock x:Name="BackgroundStateText" Text="Background clipping: Stopped"/>
                    <TextBlock Text="Hotkey: Shift + R"/>
                </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Capture Target" FontSize="20" FontWeight="SemiBold"/>
                    <Button Content="Pick display or window"
                            Click="PickTargetButton_Click"/>
                </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Audio" FontSize="20" FontWeight="SemiBold"/>

                    <ToggleSwitch x:Name="IncludeSystemAudioToggle"
                                  Header="Include system audio"
                                  IsOn="True"/>

                    <ComboBox x:Name="RenderDevicesComboBox"
                              Header="Sound source"
                              DisplayMemberPath="Name"/>

                    <ToggleSwitch x:Name="IncludeMicrophoneToggle"
                                  Header="Include microphone"
                                  IsOn="False"/>

                    <ComboBox x:Name="MicDevicesComboBox"
                              Header="Microphone"
                              DisplayMemberPath="Name"/>
                </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Manual Recording" FontSize="20" FontWeight="SemiBold"/>
                    <Button Content="Start manual recording"
                            Click="StartManualRecordingButton_Click"/>
                    <Button Content="Stop manual recording"
                            Click="StopManualRecordingButton_Click"/>
                </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Background Clipping" FontSize="20" FontWeight="SemiBold"/>
                    <Button Content="Start background clipping"
                            Click="StartBackgroundButton_Click"/>
                    <Button Content="Stop background clipping"
                            Click="StopBackgroundButton_Click"/>
                    <Button Content="Save last 45 seconds now"
                            Click="SaveLast45SecondsButton_Click"/>
                    <ToggleSwitch x:Name="RunAtStartupToggle"
                                  Header="Run at sign-in"
                                  Toggled="RunAtStartupToggle_Toggled"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>