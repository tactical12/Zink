<Page
    x:Class="Zink.Pages.LikedRadioSongsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Zink.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24"
          RowDefinitions="Auto,*">

        <TextBlock Grid.Row="0"
                   Text="Liked radio songs"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <ListView x:Name="List"
                      IsItemClickEnabled="False"
                      ItemsSource="{x:Bind Likes, Mode=OneWay}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollMode="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.HorizontalScrollMode="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LikedRadioSong">
                        <Grid Margin="0,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="56" Height="56" CornerRadius="8" Background="#2A2A2A">
                                <Image Loaded="ArtworkImage_Loaded" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind Title}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Artist}"
                                           Opacity="0.85"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Album}"
                                           Opacity="0.65"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind StationName}"
                                           Opacity="0.65"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <Button Content="{x:Bind SpotifyButtonText}"
                                        IsEnabled="{x:Bind CanAddToSpotify}"
                                        Click="AddToSpotify_Click"
                                        Tag="{x:Bind Id}" />
                                <Button Content="Play in Spotify"
                                        Click="PlayInSpotify_Click"
                                        Tag="{x:Bind Id}" />
                                <Button Content="Play with YouTube"
                                        Click="PlayWithYouTube_Click"
                                        Tag="{x:Bind Id}" />
                                <Button Content="Remove"
                                        Click="Remove_Click"
                                        Tag="{x:Bind Id}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock x:Name="EmptyHint"
                       Text="No liked songs yet. Play a station and tap Like song."
                       Opacity="0.7"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>