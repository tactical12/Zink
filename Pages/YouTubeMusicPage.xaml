<Page
    x:Class="Zink.Pages.YouTubeMusicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Simple loading state -->
        <Grid x:Name="LoadingOverlay" Background="Transparent">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="44" Height="44"/>
                <TextBlock Text="Loading YouTube Music…" Opacity="0.8"/>
            </StackPanel>
        </Grid>

        <!-- WebView2 -->
        <WebView2 x:Name="MyWebView"
                  Visibility="Collapsed"
                  NavigationCompleted="MyWebView_NavigationCompleted"/>
    </Grid>
</Page>
