<Page
    x:Class="Zink.Pages.AmazonMusicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Simple top bar -->
        <StackPanel Orientation="Horizontal" Spacing="8" Padding="8" Background="{ThemeResource SystemControlAcrylicElementBrush}">
            <TextBlock Text="Amazon Music" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Margin="0,44,0,0">
            <WebView2 x:Name="MyWebView" DefaultBackgroundColor="Transparent"/>
        </Grid>
    </Grid>
</Page>
