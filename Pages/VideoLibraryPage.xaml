<Page
    x:Class="Zink.Pages.VideoLibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Zink.Pages"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + actions -->
        <StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Video Library" FontSize="28" FontWeight="SemiBold" />
                <Button x:Name="AddFolderButton" Content="Add Folder" Click="AddFolderButton_Click" />
                <Button x:Name="RescanButton" Content="Rescan" Click="RescanButton_Click" />
            </StackPanel>

            <!-- ? NEW: Background scan status (spinner + message) -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ProgressRing x:Name="LibraryStatusRing"
                              Width="18"
                              Height="18"
                              IsActive="False"
                              Visibility="Collapsed"/>
                <TextBlock x:Name="LibraryStatusText"
                           Opacity="0.75"
                           Text=""
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </StackPanel>

        <!-- Thumbnails -->
        <GridView Grid.Row="1"
                  ItemsSource="{x:Bind Videos, Mode=OneWay}"
                  IsItemClickEnabled="True"
                  ItemClick="GridView_ItemClick"
                  SelectionMode="None">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="0"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <!-- Each item -->
            <GridView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="220" Spacing="8">
                        <Border CornerRadius="12" Height="124" Background="#202020">
                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding DurationText}" Opacity="0.7" FontSize="12"/>

                        <!-- Button still here -->
                        <Button Content="Play with the Zink Video Player"
                                Click="PlayWithVideoPlayer_Click"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
