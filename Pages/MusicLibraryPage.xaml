<Page
    x:Class="Zink.Pages.MusicLibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>

        <!-- Subtle overlays for hover/pressed/selected. Works on dark + light themes. -->
        <SolidColorBrush x:Key="RowHoverOverlayBrush" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="RowPressedOverlayBrush" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="RowSelectedOverlayBrush" Color="#18FFFFFF"/>

        <!-- Custom ListViewItem style: removes default hover/selection rectangle and drives our card states -->
        <Style x:Key="MusicLibraryRowItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>

                            <!-- Our card row container -->
                            <Border x:Name="Card"
                                    CornerRadius="12"
                                    Margin="12,0,12,10"
                                    Padding="12"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                                <Grid>
                                    <!-- Overlay that we fade in/out via VisualStates -->
                                    <Border x:Name="Overlay"
                                            CornerRadius="12"
                                            Background="{StaticResource RowHoverOverlayBrush}"
                                            Opacity="0"/>

                                    <!-- The row content from your DataTemplate -->
                                    <ContentPresenter x:Name="ContentPresenter"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Grid>
                            </Border>

                            <!-- Keep focus visuals fully off -->
                            <Border x:Name="FocusVisual"
                                    IsHitTestVisible="False"
                                    BorderThickness="0"
                                    Background="Transparent"/>
                        </Grid>

                        <VisualStateManager.VisualStateGroups>

                            <!-- Hover/Pressed -->
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="Overlay.Opacity" Value="0"/>
                                        <Setter Target="Overlay.Background" Value="{StaticResource RowHoverOverlayBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Overlay.Background" Value="{StaticResource RowHoverOverlayBrush}"/>
                                        <Setter Target="Overlay.Opacity" Value="1"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Overlay.Background" Value="{StaticResource RowPressedOverlayBrush}"/>
                                        <Setter Target="Overlay.Opacity" Value="1"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Card.Opacity" Value="0.6"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <!-- Selection (accent outline) -->
                            <VisualStateGroup x:Name="SelectionStates">
                                <VisualState x:Name="Unselected">
                                    <VisualState.Setters>
                                        <Setter Target="Card.BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                        <Setter Target="Card.BorderThickness" Value="1"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="Card.BorderBrush" Value="{ThemeResource SystemAccentColor}"/>
                                        <Setter Target="Card.BorderThickness" Value="2"/>
                                        <Setter Target="Overlay.Background" Value="{StaticResource RowSelectedOverlayBrush}"/>
                                        <Setter Target="Overlay.Opacity" Value="1"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="SelectedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Card.BorderBrush" Value="{ThemeResource SystemAccentColor}"/>
                                        <Setter Target="Card.BorderThickness" Value="2"/>
                                        <Setter Target="Overlay.Background" Value="{StaticResource RowSelectedOverlayBrush}"/>
                                        <Setter Target="Overlay.Opacity" Value="1"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="SelectedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="Card.BorderBrush" Value="{ThemeResource SystemAccentColor}"/>
                                        <Setter Target="Card.BorderThickness" Value="2"/>
                                        <Setter Target="Overlay.Background" Value="{StaticResource RowPressedOverlayBrush}"/>
                                        <Setter Target="Overlay.Opacity" Value="1"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                        </VisualStateManager.VisualStateGroups>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <StackPanel Orientation="Horizontal" Spacing="12" Grid.Row="0">
            <Button x:Name="PickFolderButton"
                    Content="Pick Music Folder"
                    MinWidth="180"
                    Height="48"
                    FontSize="18"
                    CornerRadius="12"
                    Click="PickFolderButton_Click"
                    HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding PickedFolderPath}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="Gray"
                       FontSize="14"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Play All Button -->
        <Button x:Name="PlayAllButton"
                Content="Play All"
                Height="36"
                MinWidth="100"
                Margin="0,16,0,16"
                Click="PlayAllButton_Click"
                Grid.Row="1"/>

        <!-- Header + Song List -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Column Headers (match the card padding/margin) -->
            <Border Grid.Row="0"
                    Margin="12,0,12,6"
                    Padding="12,0,12,0"
                    Background="Transparent">
                <Grid Opacity="0.85">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="190"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Song" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="Artist" Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="Album" Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="Time" Grid.Column="3" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Song List -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding Songs}"
                      SelectionMode="Single"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ItemContainerStyle="{StaticResource MusicLibraryRowItemStyle}">

                <!-- Only row content (the card is now provided by the ListViewItem template above) -->
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>

                            <TextBlock Text="{Binding Artist}"
                                       Grid.Column="1"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>

                            <TextBlock Text="{Binding Album}"
                                       Grid.Column="2"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>

                            <TextBlock Text="{Binding Duration}"
                                       Grid.Column="3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>

                            <Button Content="Play with Media Player"
                                    Grid.Column="4"
                                    Height="34"
                                    MinWidth="160"
                                    CornerRadius="10"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Padding="12,0"
                                    Click="PlaySongButton_Click"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Grid>
    </Grid>
</Page>
